<!DOCTYPE html>
<html>
<head>
  <title>Coupons</title>
  <link rel="stylesheet" href="/css/product-management.css" />
  <style>
    [hidden] { display: none !important; }
    .coupon-readonly { background: #f6f8fc; }
    .coupon-action-stack {
      display: grid;
      gap: 8px;
    }
    .coupon-action-stack .btn {
      width: 100%;
      min-width: 0;
    }
  </style>
</head>
<body>
<main class="dashboard-scene">
<section class="dashboard-card">
  <%- include("partials/admin-navbar", { active: "coupons" }) %>

  <section class="hero-panel">
    <div class="hero-copy">
      <h1>Coupon Management</h1>
      <p>Create and delete checkout coupons.</p>
    </div>
  </section>

  <% if (message) { %><p class="feedback success"><%= message %></p><% } %>
  <% if (error) { %><p class="feedback error"><%= error %></p><% } %>

  <form method="POST" action="/api/admin/coupons" class="toolbar-grid">
    <input name="code" placeholder="Code" required />
    <select name="discountType">
      <option value="flat">Flat</option>
      <option value="percentage">Percentage</option>
    </select>
    <input name="discountValue" type="number" min="1" placeholder="Discount" required />
    <input name="maxDiscount" type="number" min="0" placeholder="Max discount" />
    <input name="minOrderAmount" type="number" min="0" placeholder="Min order" />
    <input name="usageLimit" type="number" min="0" placeholder="Usage limit" />
    <input name="expiresAt" type="date" />
    <button class="btn btn-dark">Create</button>
  </form>

  <div class="table-wrap">
    <table class="product-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Type</th>
          <th>Value</th>
          <th>Min</th>
          <th>Used</th>
          <th>Expiry</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
      <% coupons.forEach((coupon) => { %>
        <tr>
          <td>
            <input form="coupon-update-<%= coupon._id %>" name="code" value="<%= coupon.code %>" required data-coupon-field data-coupon-row="<%= coupon._id %>" />
          </td>
          <td>
            <select form="coupon-update-<%= coupon._id %>" name="discountType" data-coupon-field data-coupon-row="<%= coupon._id %>">
                <option value="flat" <%= coupon.discountType === "flat" ? "selected" : "" %>>Flat</option>
                <option value="percentage" <%= coupon.discountType === "percentage" ? "selected" : "" %>>Percentage</option>
            </select>
          </td>
          <td>
            <input form="coupon-update-<%= coupon._id %>" name="discountValue" type="number" min="1" value="<%= coupon.discountValue %>" required data-coupon-field data-coupon-row="<%= coupon._id %>" />
          </td>
          <td>
            <input form="coupon-update-<%= coupon._id %>" name="minOrderAmount" type="number" min="0" value="<%= coupon.minOrderAmount %>" data-coupon-field data-coupon-row="<%= coupon._id %>" />
          </td>
          <td>
            <%= coupon.usedCount %>/<%= coupon.usageLimit || "∞" %>
          </td>
          <td>
            <input form="coupon-update-<%= coupon._id %>" name="expiresAt" type="date" value="<%= coupon.expiresAt ? new Date(coupon.expiresAt).toISOString().slice(0,10) : '' %>" data-coupon-field data-coupon-row="<%= coupon._id %>" />
          </td>
          <td>
            <select form="coupon-update-<%= coupon._id %>" name="isActive" data-coupon-field data-coupon-row="<%= coupon._id %>">
                <option value="true" <%= coupon.isActive ? "selected" : "" %>>Active</option>
                <option value="false" <%= !coupon.isActive ? "selected" : "" %>>Inactive</option>
            </select>
            <div class="coupon-action-stack" style="margin-top:8px;">
              <button class="btn btn-dark" type="button" data-coupon-edit data-coupon-row="<%= coupon._id %>">Edit</button>
              <button class="btn btn-dark" type="submit" form="coupon-update-<%= coupon._id %>" data-coupon-save data-coupon-row="<%= coupon._id %>" hidden>Save</button>
              <button class="btn btn-light" type="button" data-coupon-cancel data-coupon-row="<%= coupon._id %>" hidden>Cancel</button>
              <button class="btn btn-light" type="submit" form="coupon-delete-<%= coupon._id %>" data-coupon-delete data-coupon-row="<%= coupon._id %>">Delete</button>
            </div>
            <form id="coupon-update-<%= coupon._id %>" method="POST" action="/api/admin/coupons/<%= coupon._id %>/update" hidden>
              <input type="hidden" name="usageLimit" value="<%= coupon.usageLimit %>" />
              <input type="hidden" name="maxDiscount" value="<%= coupon.maxDiscount %>" />
              <input type="hidden" name="description" value="<%= coupon.description || '' %>" />
            </form>
            <form id="coupon-delete-<%= coupon._id %>" method="POST" action="/api/admin/coupons/<%= coupon._id %>/delete" hidden></form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>
</main>
<script>
  const couponRows = new Set(
    Array.from(document.querySelectorAll("[data-coupon-row]")).map(function(node) {
      return node.getAttribute("data-coupon-row");
    })
  );

  const setCouponRowMode = function(rowId, editing, resetValues) {
    const fields = document.querySelectorAll('[data-coupon-field][data-coupon-row="' + rowId + '"]');
    const editBtn = document.querySelector('[data-coupon-edit][data-coupon-row="' + rowId + '"]');
    const saveBtn = document.querySelector('[data-coupon-save][data-coupon-row="' + rowId + '"]');
    const cancelBtn = document.querySelector('[data-coupon-cancel][data-coupon-row="' + rowId + '"]');
    const deleteBtn = document.querySelector('[data-coupon-delete][data-coupon-row="' + rowId + '"]');

    fields.forEach(function(field) {
      if (resetValues) {
        field.value = field.dataset.originalValue || "";
      }
      field.disabled = !editing;
      field.classList.toggle("coupon-readonly", !editing);
    });

    if (editBtn) editBtn.hidden = editing;
    if (saveBtn) saveBtn.hidden = !editing;
    if (cancelBtn) cancelBtn.hidden = !editing;
    if (deleteBtn) deleteBtn.hidden = editing;
  };

  couponRows.forEach(function(rowId) {
    document.querySelectorAll('[data-coupon-field][data-coupon-row="' + rowId + '"]').forEach(function(field) {
      field.dataset.originalValue = field.value;
    });
    setCouponRowMode(rowId, false, false);
  });

  document.querySelectorAll("[data-coupon-edit]").forEach(function(button) {
    button.addEventListener("click", function() {
      setCouponRowMode(button.getAttribute("data-coupon-row"), true, false);
    });
  });

  document.querySelectorAll("[data-coupon-cancel]").forEach(function(button) {
    button.addEventListener("click", function() {
      setCouponRowMode(button.getAttribute("data-coupon-row"), false, true);
    });
  });
</script>
</body>
</html>
