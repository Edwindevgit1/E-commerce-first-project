<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= pageTitle %></title>

<link rel="stylesheet" href="/css/product-management.css" />
<link rel="stylesheet" href="/vendor/cropper/cropper.min.css" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
rel="stylesheet"
/>
</head>
<body>
<%
const productFormData = formData || {};
const productFieldErrors = validationErrors || {};
const highlightValues = Array.isArray(productFormData.highlights) ? productFormData.highlights : [];
const initialVariants = Array.isArray(productFormData.variants) ? productFormData.variants : [];
const serializedVariants = JSON.stringify(initialVariants).replace(/</g, "\\u003c");
const getFieldError = (key) => productFieldErrors[key];
%>

<main class="dashboard-scene">
<section class="dashboard-card">

<%- include("partials/admin-navbar", { active: "products" }) %>

<section class="hero-panel add-hero">
<div class="hero-copy">
<h1><%= formTitle %></h1>
<p>Manage product details, highlights, and variant-specific pricing, stock, and images.</p>
</div>

<div class="hero-actions">
<a href="/api/admin/products" class="btn btn-light">Back to List</a>
</div>
</section>

<section class="content-panel">
<% if (typeof error !== "undefined" && error) { %>
<p id="errorMessage" class="feedback error"><%= error %></p>
<% } %>

<form
class="product-form"
method="POST"
action="<%= formAction %>"
enctype="multipart/form-data"
novalidate
>
<input type="hidden" id="variantsPayload" name="variantsPayload" value="">

<div class="panel-head">
<div>
<h2>Product Details</h2>
<p>Fill the shared product information first. Variant-specific inventory lives below.</p>
</div>
</div>

<div class="form-grid">
<label class="field">
<span>Product Name</span>
<input
type="text"
name="productName"
placeholder="Nike Air 212"
value="<%= productFormData.productName || '' %>"
data-form-field="productName"
/>
<% if (getFieldError("productName")) { %>
<small class="feedback error" data-field-error="productName"><%= getFieldError("productName") %></small>
<% } %>
</label>

<label class="field">
<span>Category</span>
<select name="category" data-form-field="category">
<option value="">Select category</option>
<% if (Array.isArray(categories) && categories.length > 0) { %>
<% categories.forEach((category) => { %>
<option
value="<%= category._id %>"
<%= String(productFormData.category || "") === String(category._id) ? "selected" : "" %>
>
<%= category.name %>
</option>
<% }) %>
<% } %>
</select>
<% if (getFieldError("category")) { %>
<small class="feedback error" data-field-error="category"><%= getFieldError("category") %></small>
<% } %>
</label>

<label class="field">
<span>Status</span>
<select name="status">
<option value="active" <%= productFormData.status === "active" || !productFormData.status ? "selected" : "" %>>Active</option>
<option value="inactive" <%= productFormData.status === "inactive" ? "selected" : "" %>>Inactive</option>
</select>
<% if (getFieldError("status")) { %>
<small class="feedback error"><%= getFieldError("status") %></small>
<% } %>
</label>

<label class="field">
<span>Coupon Code</span>
<input
type="text"
name="couponCode"
placeholder="SAVE10"
value="<%= productFormData.couponCode || '' %>"
/>
<% if (getFieldError("couponCode")) { %>
<small class="feedback error"><%= getFieldError("couponCode") %></small>
<% } %>
</label>

<label class="field field-wide">
<span>Coupon Description</span>
<input
type="text"
name="couponDescription"
placeholder="Save more on this item"
value="<%= productFormData.couponDescription || '' %>"
/>
<% if (getFieldError("couponDescription")) { %>
<small class="feedback error"><%= getFieldError("couponDescription") %></small>
<% } %>
</label>

<section class="field builder-field field-wide">
<span>Highlights</span>
<input
type="hidden"
name="highlights"
id="highlightsHidden"
value="<%= highlightValues.join(', ') %>"
/>

<div class="value-builder">
  <div class="builder-input-row">
    <input type="text" id="highlightDraftInput" placeholder="Enter a product highlight" />
    <button type="button" class="btn btn-light builder-add-btn" id="addHighlightBtn">+ Add Highlight</button>
  </div>
  <div class="builder-chip-list" id="highlightChipList"></div>
</div>
</section>

<label class="field field-wide">
<span>Description</span>
<textarea
name="description"
rows="5"
placeholder="Write a short description"
><%= productFormData.description || '' %></textarea>
<% if (getFieldError("description")) { %>
<small class="feedback error"><%= getFieldError("description") %></small>
<% } %>
</label>

<label class="field field-wide">
<span>Shipping Info</span>
<textarea
name="shippingInfo"
rows="4"
placeholder="Enter delivery, dispatch, or return information"
><%= productFormData.shippingInfo || '' %></textarea>
<% if (getFieldError("shippingInfo")) { %>
<small class="feedback error"><%= getFieldError("shippingInfo") %></small>
<% } %>
</label>
</div>

<section class="inner-panel">
<div class="panel-head">
<div>
<h2>Variants</h2>
<p>Each variant manages its own size, color, price, stock, and minimum 3 images.</p>
</div>
<button type="button" class="btn btn-light" id="addVariantBtn">+ Add Variant</button>
</div>

<% if (getFieldError("variants")) { %>
<p class="feedback error"><%= getFieldError("variants") %></p>
<% } %>

<div id="variantList" class="variant-list-admin"></div>
</section>

<div class="form-actions end-actions">
<a href="/api/admin/products" class="btn btn-light">Cancel</a>
<button type="submit" class="btn btn-dark"><%= submitLabel %></button>
</div>
</form>
</section>

</section>
</main>

<div class="crop-modal-backdrop" id="cropModalBackdrop" aria-hidden="true">
  <div class="crop-modal-box" role="dialog" aria-modal="true" aria-labelledby="cropModalTitle">
    <div class="crop-modal-head">
      <h3 id="cropModalTitle">Crop Image</h3>
      <p>Adjust the image before adding it to this variant.</p>
    </div>

    <div class="crop-image-wrap">
      <img id="cropModalImage" alt="Crop preview" />
    </div>

    <div class="crop-modal-actions">
      <button type="button" class="btn btn-light" id="cancelCropBtn">Cancel</button>
      <button type="button" class="btn btn-dark" id="applyCropBtn">Apply Crop</button>
    </div>
  </div>
</div>

<script src="/vendor/cropper/cropper.min.js"></script>
<script>
window.addEventListener("pageshow", function (event) {
  if (event.persisted) {
    window.location.reload();
  }
});

window.addEventListener("load", () => {
  history.pushState({ productFormLocked: true }, "", location.href);
});

window.addEventListener("popstate", () => {
  window.history.go(1);
});

const errorMessage = document.getElementById("errorMessage");
const productForm = document.querySelector(".product-form");
const variantList = document.getElementById("variantList");
const addVariantBtn = document.getElementById("addVariantBtn");
const variantsPayloadInput = document.getElementById("variantsPayload");
const productNameInput = productForm?.querySelector('[data-form-field="productName"]');
const categorySelect = productForm?.querySelector('[data-form-field="category"]');
const highlightsHidden = document.getElementById("highlightsHidden");
const highlightDraftInput = document.getElementById("highlightDraftInput");
const addHighlightBtn = document.getElementById("addHighlightBtn");
const highlightChipList = document.getElementById("highlightChipList");
const cropModalBackdrop = document.getElementById("cropModalBackdrop");
const cropModalImage = document.getElementById("cropModalImage");
const cancelCropBtn = document.getElementById("cancelCropBtn");
const applyCropBtn = document.getElementById("applyCropBtn");

const fieldErrors = <%- JSON.stringify(productFieldErrors).replace(/</g, "\\u003c") %>;
const initialVariants = <%- serializedVariants %>;
let highlightValues = <%- JSON.stringify(highlightValues).replace(/</g, "\\u003c") %>;
const transientFieldErrors = {};
const transientFieldErrorTimeouts = {};
let cropperInstance = null;
let cropSession = null;
let variantsState = Array.isArray(initialVariants) && initialVariants.length
  ? initialVariants.map(createVariantState)
  : [createVariantState()];

if (errorMessage) {
  setTimeout(() => {
    errorMessage.style.display = "none";
  }, 3000);
}

function createVariantState(variant = {}) {
  const existingImages = Array.isArray(variant.images)
    ? variant.images.map((image) => ({
        url: typeof image === "string" ? image : (image?.url || ""),
        originalUrl: typeof image === "string" ? image : (image?.originalUrl || image?.url || ""),
        cropData: typeof image === "string" ? null : (image?.cropData || null),
        removed: false
      }))
    : [];
  const mainImageIndex = Number.isInteger(variant.mainImageIndex) ? variant.mainImageIndex : 0;

  return {
    size: variant.size || "",
    color: variant.color || "",
    price: variant.price ?? "",
    offerPrice: variant.offerPrice ?? "",
    stock: variant.stock ?? "",
    existingImages,
    newImages: [],
    mainImageKey: existingImages[mainImageIndex]
      ? `existing:${mainImageIndex}`
      : existingImages.length
        ? "existing:0"
        : ""
  };
}

function getStaticFieldErrorNode(key) {
  return document.querySelector(`[data-field-error="${key}"]`);
}

function ensureStaticFieldErrorNode(key) {
  let node = getStaticFieldErrorNode(key);
  if (node) return node;

  const input = productForm?.querySelector(`[data-form-field="${key}"]`);
  const fieldWrapper = input?.closest(".field");
  if (!fieldWrapper) return null;

  node = document.createElement("small");
  node.className = "feedback error";
  node.dataset.fieldError = key;
  fieldWrapper.appendChild(node);
  return node;
}

function clearStaticFieldError(key) {
  const node = getStaticFieldErrorNode(key);
  if (!node) return;

  if (transientFieldErrorTimeouts[key]) {
    window.clearTimeout(transientFieldErrorTimeouts[key]);
    delete transientFieldErrorTimeouts[key];
  }

  node.remove();
}

function setStaticFieldError(key, message) {
  const node = ensureStaticFieldErrorNode(key);
  if (!node) return;

  clearStaticFieldError(key);
  const refreshedNode = ensureStaticFieldErrorNode(key);
  if (!refreshedNode) return;
  refreshedNode.textContent = message;

  transientFieldErrorTimeouts[key] = window.setTimeout(() => {
    const currentNode = getStaticFieldErrorNode(key);
    currentNode?.remove();
    delete transientFieldErrorTimeouts[key];
  }, 3000);
}

function getVariantFieldError(index, field) {
  return transientFieldErrors[`variants.${index}.${field}`] || fieldErrors[`variants.${index}.${field}`] || "";
}

function clearTransientFieldError(key) {
  if (transientFieldErrorTimeouts[key]) {
    window.clearTimeout(transientFieldErrorTimeouts[key]);
    delete transientFieldErrorTimeouts[key];
  }

  if (transientFieldErrors[key]) {
    delete transientFieldErrors[key];
  }
}

function setTransientFieldError(key, message) {
  clearTransientFieldError(key);
  transientFieldErrors[key] = message;
  renderVariants();

  transientFieldErrorTimeouts[key] = window.setTimeout(() => {
    delete transientFieldErrors[key];
    delete transientFieldErrorTimeouts[key];
    renderVariants();
  }, 3000);
}

function getActiveVariantImages(variant) {
  const activeExisting = variant.existingImages
    .map((image, index) => ({ ...image, kind: "existing", index }))
    .filter((image) => !image.removed);
  const activeNew = variant.newImages.map((file, index) => ({
    file,
    kind: "new",
    index
  }));

  return [...activeExisting, ...activeNew];
}

function normalizeVariantMainImage(variant) {
  const activeImages = getActiveVariantImages(variant);
  const activeKeys = activeImages.map((image) => `${image.kind}:${image.index}`);

  if (!activeKeys.includes(variant.mainImageKey)) {
    variant.mainImageKey = activeKeys[0] || "";
  }
}

function attachSelectedFiles(input, files) {
  const dataTransfer = new DataTransfer();
  files.forEach((file) => {
    const originalFile = file?.originalFile || file?.originalSourceFile || file;
    if (originalFile) {
      dataTransfer.items.add(originalFile);
    }
  });
  input.files = dataTransfer.files;
}

const allowedImageMimeTypes = new Set(["image/jpeg", "image/png"]);
const allowedImageExtensions = new Set(["jpg", "jpeg", "png"]);

function isAllowedImageFile(file) {
  if (!file) return false;

  const mimeType = String(file.type || "").toLowerCase();
  if (allowedImageMimeTypes.has(mimeType)) {
    return true;
  }

  const fileName = String(file.name || "");
  const extension = fileName.includes(".")
    ? fileName.split(".").pop().toLowerCase()
    : "";

  return allowedImageExtensions.has(extension);
}

function getInvalidImageUploadMessage() {
  return "This file can't be added. Only JPG and PNG images are allowed.";
}

function ensurePreviewUrl(file, key = "previewUrl") {
  if (!file) return "";
  if (!file[key]) {
    file[key] = URL.createObjectURL(file);
  }
  return file[key];
}

function openCropModalWithPreview(previewUrl, cropperOptions = {}, errorKey = "", cropData = null) {
  if (!previewUrl || !cropModalImage) {
    throw new Error("Unable to load the image preview for cropping.");
  }

  cropModalBackdrop?.classList.add("show");
  cropModalBackdrop?.setAttribute("aria-hidden", "false");

  cropModalImage.onload = null;
  cropModalImage.onerror = () => {
    closeCropModal();
    renderVariants();
    if (errorKey) {
      setTransientFieldError(errorKey, "Unable to load the image preview for cropping.");
    }
  };

  cropModalImage.onload = () => {
    if (cropperInstance) {
      cropperInstance.destroy();
    }

    cropperInstance = new Cropper(cropModalImage, {
      aspectRatio: NaN,
      viewMode: 1,
      dragMode: "move",
      autoCropArea: 1,
      responsive: true,
      background: false,
      ready() {
        if (cropData) {
          cropperInstance?.setData(cropData);
        }
      },
      ...cropperOptions
    });
  };

  cropModalImage.removeAttribute("src");
  cropModalImage.src = previewUrl;

  if (cropModalImage.complete && cropModalImage.naturalWidth > 0) {
    cropModalImage.onload();
  }
}

function getFileExtension(file) {
  const name = String(file?.name || "");
  const match = name.match(/\.([^.]+)$/);
  return match ? match[1].toLowerCase() : "jpg";
}

function buildCroppedFileName(file, index) {
  const baseName = String(file?.name || `variant-image-${Date.now()}-${index}`)
    .replace(/\.[^.]+$/, "")
    .replace(/\s+/g, "-");
  const extension = getFileExtension(file);
  return `${baseName}-cropped.${extension}`;
}

async function buildReplacementSourceFile(image, index) {
  if (image.kind === "new") {
    const sourceFile = image.file.originalSourceFile || image.file;
    return {
      sourceFile,
      previewUrl:
        sourceFile.originalPreviewUrl ||
        ensurePreviewUrl(sourceFile, "originalPreviewUrl") ||
        sourceFile.previewUrl ||
        ensurePreviewUrl(sourceFile),
      cropData: image.file.cropData || null
    };
  }

  const response = await fetch(image.originalUrl || image.url);
  if (!response.ok) {
    throw new Error("Unable to load the selected image for cropping.");
  }

  const blob = await response.blob();
  const extension = blob.type === "image/png" ? "png" : "jpg";
  const file = new File(
    [blob],
    `variant-existing-${Date.now()}-${index}.${extension}`,
    { type: blob.type || "image/jpeg", lastModified: Date.now() }
  );

  file.previewUrl = ensurePreviewUrl(file);
  file.originalPreviewUrl = image.originalUrl || image.url || file.previewUrl;
  file.isTemporaryReplacementSource = true;
  return {
    sourceFile: file,
    previewUrl: file.originalPreviewUrl || file.previewUrl,
    cropData: image.cropData || null
  };
}

function revokeCropPreviewUrl() {
  if (cropSession?.previewUrl && !cropSession?.keepPreviewUrl) {
    URL.revokeObjectURL(cropSession.previewUrl);
  }
}

function closeCropModal() {
  if (cropperInstance) {
    cropperInstance.destroy();
    cropperInstance = null;
  }

  revokeCropPreviewUrl();

  if (cropModalImage) {
    cropModalImage.removeAttribute("src");
  }

  cropModalBackdrop?.classList.remove("show");
  cropModalBackdrop?.setAttribute("aria-hidden", "true");
  cropSession = null;
}

async function applyCropAndContinue() {
  if (!cropSession || !cropperInstance) return;

  const { variantIndex, mode, fileIndex = 0 } = cropSession;
  const sourceFile =
    mode === "replace"
      ? cropSession.sourceFile
      : cropSession.files[cropSession.fileIndex];

  const canvas = cropperInstance.getCroppedCanvas({
    maxWidth: 1600,
    maxHeight: 1600,
    imageSmoothingEnabled: true,
    imageSmoothingQuality: "high"
  });

  if (!canvas) {
    closeCropModal();
    return;
  }

  const outputType = sourceFile.type === "image/png" ? "image/png" : "image/jpeg";
  const blob = await new Promise((resolve) => {
    canvas.toBlob(resolve, outputType, 0.92);
  });

  if (!blob) {
    closeCropModal();
    return;
  }

  const croppedFile = new File(
    [blob],
    buildCroppedFileName(sourceFile, fileIndex),
    { type: outputType, lastModified: Date.now() }
  );

  const cropData = cropperInstance.getData(true);
  const pendingImage = {
    originalFile: sourceFile.originalSourceFile || sourceFile,
    originalSourceFile: sourceFile.originalSourceFile || sourceFile,
    cropData,
    previewUrl: ensurePreviewUrl(croppedFile),
    originalPreviewUrl:
      (sourceFile.originalSourceFile || sourceFile)?.originalPreviewUrl ||
      ensurePreviewUrl(sourceFile.originalSourceFile || sourceFile, "originalPreviewUrl") ||
      (sourceFile.originalSourceFile || sourceFile)?.previewUrl ||
      ensurePreviewUrl(sourceFile.originalSourceFile || sourceFile)
  };

  if (mode === "replace") {
    const variant = variantsState[variantIndex];
    const targetImage = cropSession.targetImage;
    const wasMainImage = variant.mainImageKey === `${targetImage.kind}:${targetImage.index}`;

    if (targetImage.kind === "existing") {
      variant.existingImages[targetImage.index].removed = true;
      variant.newImages.push(pendingImage);
      if (wasMainImage) {
        variant.mainImageKey = `new:${variant.newImages.length - 1}`;
      }
    } else {
      const previousFile = variant.newImages[targetImage.index];
      if (previousFile?.previewUrl) {
        URL.revokeObjectURL(previousFile.previewUrl);
      }

      variant.newImages.splice(targetImage.index, 1, pendingImage);
      if (wasMainImage) {
        variant.mainImageKey = `new:${targetImage.index}`;
      }
    }

    if (
      sourceFile?.isTemporaryReplacementSource &&
      sourceFile.previewUrl &&
      sourceFile.previewUrl !== sourceFile.originalPreviewUrl
    ) {
      URL.revokeObjectURL(sourceFile.previewUrl);
    }

    clearTransientFieldError(`variants.${variantIndex}.images`);
    closeCropModal();
    renderVariants();
    return;
  }

  cropSession.acceptedFiles.push(pendingImage);
  openCropModalForFile(
    variantIndex,
    cropSession.files,
    cropSession.fileIndex + 1,
    cropSession.acceptedFiles
  );
}

function openCropModalForFile(variantIndex, files, fileIndex = 0, acceptedFiles = []) {
  const nextFile = files[fileIndex];

  if (!nextFile) {
    if (acceptedFiles.length) {
      variantsState[variantIndex].newImages.push(...acceptedFiles);
      clearTransientFieldError(`variants.${variantIndex}.images`);
      renderVariants();
    }

    closeCropModal();
    return;
  }

  if (cropperInstance) {
    cropperInstance.destroy();
    cropperInstance = null;
  }

  revokeCropPreviewUrl();

  if (!nextFile.originalPreviewUrl) {
    nextFile.originalPreviewUrl = ensurePreviewUrl(nextFile, "originalPreviewUrl");
  }

  const previewUrl = nextFile.originalPreviewUrl;
  cropSession = {
    variantIndex,
    files,
    fileIndex,
    acceptedFiles,
    previewUrl,
    keepPreviewUrl: true
  };

  openCropModalWithPreview(previewUrl, {}, `variants.${variantIndex}.images`);
}

function openCropModalForReplacement(variantIndex, image, sourceFile, previewUrl = "", cropData = null) {
  if (cropperInstance) {
    cropperInstance.destroy();
    cropperInstance = null;
  }

  revokeCropPreviewUrl();

  const resolvedPreviewUrl =
    previewUrl ||
    sourceFile?.previewUrl ||
    image?.file?.previewUrl ||
    sourceFile?.originalPreviewUrl ||
    image?.file?.originalPreviewUrl ||
    image?.originalUrl ||
    image?.url ||
    "";
  cropSession = {
    mode: "replace",
    variantIndex,
    targetImage: image,
    sourceFile,
    previewUrl: resolvedPreviewUrl,
    cropData: cropData || image?.file?.cropData || null,
    keepPreviewUrl: true
  };

  openCropModalWithPreview(
    resolvedPreviewUrl,
    {},
    `variants.${variantIndex}.images`,
    cropData || image?.file?.cropData || null
  );
}

function renderVariants() {
  variantList.innerHTML = "";

  variantsState.forEach((variant, index) => {
    normalizeVariantMainImage(variant);

    const card = document.createElement("section");
    card.className = "glass-panel";
    card.style.marginBottom = "1rem";
    card.innerHTML = `
      <div class="panel-head">
        <div>
          <h3>Variant ${index + 1}</h3>
          <p>Set size, color, pricing, stock, and images for this option.</p>
        </div>
        <button type="button" class="btn btn-light" data-remove-variant="${index}" ${variantsState.length === 1 ? "disabled" : ""}>Remove</button>
      </div>

      <div class="form-grid">
        <label class="field">
          <span>Size</span>
          <input type="text" value="${escapeHtml(variant.size)}" data-variant-input="${index}" data-field="size" placeholder="8 / M / 42" />
          ${renderInlineError(getVariantFieldError(index, "size"))}
        </label>

        <label class="field">
          <span>Color</span>
          <input type="text" value="${escapeHtml(variant.color)}" data-variant-input="${index}" data-field="color" placeholder="Black" />
          ${renderInlineError(getVariantFieldError(index, "color"))}
        </label>

        <label class="field">
          <span>Price</span>
          <input type="number" min="1" step="0.01" value="${escapeHtml(variant.price)}" data-variant-input="${index}" data-field="price" placeholder="3695" />
          ${renderInlineError(getVariantFieldError(index, "price"))}
        </label>

        <label class="field">
          <span>Offer Price</span>
          <input type="number" min="0" step="0.01" value="${escapeHtml(variant.offerPrice)}" data-variant-input="${index}" data-field="offerPrice" placeholder="2999" />
          ${renderInlineError(getVariantFieldError(index, "offerPrice"))}
        </label>

        <label class="field">
          <span>Stock</span>
          <input type="number" min="0" step="1" value="${escapeHtml(variant.stock)}" data-variant-input="${index}" data-field="stock" placeholder="10" />
          ${renderInlineError(getVariantFieldError(index, "stock"))}
        </label>

        <label class="field field-wide">
          <span>Upload Images</span>
          <input type="file" multiple accept="image/jpeg,image/jpg,image/png" data-variant-file="${index}" name="variantImages-${index}" />
          ${renderInlineError(getVariantFieldError(index, "images"))}
        </label>
      </div>

      <div class="image-preview-row" data-variant-images="${index}"></div>
    `;

    variantList.appendChild(card);

    const fileInput = card.querySelector(`[data-variant-file="${index}"]`);
    if (fileInput) {
      attachSelectedFiles(fileInput, variant.newImages);

      fileInput.addEventListener("change", (event) => {
        const files = Array.from(event.target.files || []);
        if (!files.length) return;
        event.target.value = "";

        const validFiles = files.filter(isAllowedImageFile);
        const hasInvalidFiles = validFiles.length !== files.length;

        if (hasInvalidFiles) {
          setTransientFieldError(`variants.${index}.images`, getInvalidImageUploadMessage());
        } else {
          clearTransientFieldError(`variants.${index}.images`);
        }

        if (!validFiles.length) {
          return;
        }

        openCropModalForFile(index, validFiles);
      });
    }

    card.querySelectorAll(`[data-variant-input="${index}"]`).forEach((input) => {
      input.addEventListener("input", () => {
        variant[input.dataset.field] = input.value;
        clearTransientFieldError(`variants.${index}.${input.dataset.field}`);
      });
    });

    const previewRow = card.querySelector(`[data-variant-images="${index}"]`);
    getActiveVariantImages(variant).forEach((image) => {
      const imageBox = document.createElement("div");
      imageBox.className = "image-box";

      const imageNode = document.createElement("img");
      imageNode.src = image.kind === "existing"
        ? image.url
        : (image.file.previewUrl || image.file.originalPreviewUrl || "");
      imageNode.className = "product-image-preview recrop-image";
      imageNode.alt = `Variant ${index + 1} image`;
      imageNode.title = "Click to crop again";
      imageNode.addEventListener("click", async () => {
        try {
          const replacementSource = await buildReplacementSourceFile(image, index);
          openCropModalForReplacement(
            index,
            image,
            replacementSource.sourceFile,
            replacementSource.previewUrl,
            replacementSource.cropData
          );
        } catch (error) {
          setTransientFieldError(`variants.${index}.images`, error.message || "Unable to open the crop tool for this image.");
        }
      });

      const removeButton = document.createElement("button");
      removeButton.type = "button";
      removeButton.className = "remove-btn";
      removeButton.textContent = "✕";
      removeButton.addEventListener("click", () => {
        if (image.kind === "existing") {
          variant.existingImages[image.index].removed = true;
        } else {
          const [removedImage] = variant.newImages.splice(image.index, 1);
          if (removedImage?.previewUrl) {
            URL.revokeObjectURL(removedImage.previewUrl);
          }
          if (
            removedImage?.originalFile?.originalPreviewUrl &&
            removedImage.originalFile !== removedImage
          ) {
            URL.revokeObjectURL(removedImage.originalFile.originalPreviewUrl);
          }
        }

        normalizeVariantMainImage(variant);
        clearTransientFieldError(`variants.${index}.images`);
        renderVariants();
      });

      const mainButton = document.createElement("button");
      mainButton.type = "button";
      mainButton.className = `main-image-btn ${variant.mainImageKey === `${image.kind}:${image.index}` ? "active-main" : ""}`;
      mainButton.textContent = variant.mainImageKey === `${image.kind}:${image.index}` ? "Main Image" : "Set as Main";
      mainButton.addEventListener("click", () => {
        variant.mainImageKey = `${image.kind}:${image.index}`;
        renderVariants();
      });

      imageBox.appendChild(imageNode);
      imageBox.appendChild(removeButton);
      imageBox.appendChild(mainButton);
      previewRow.appendChild(imageBox);
    });

    if (!getActiveVariantImages(variant).length) {
      const emptyMessage = document.createElement("p");
      emptyMessage.className = "image-validation-message";
      emptyMessage.textContent = "Upload at least 3 images for this variant.";
      previewRow.appendChild(emptyMessage);
    }
  });

  document.querySelectorAll("[data-remove-variant]").forEach((button) => {
    button.addEventListener("click", () => {
      const index = Number(button.dataset.removeVariant);
      const [removedVariant] = variantsState.splice(index, 1);
      removedVariant?.newImages?.forEach((file) => {
        if (file.previewUrl) {
          URL.revokeObjectURL(file.previewUrl);
        }
        if (
          file?.originalFile?.originalPreviewUrl &&
          file.originalFile !== file
        ) {
          URL.revokeObjectURL(file.originalFile.originalPreviewUrl);
        }
      });
      renderVariants();
    });
  });
}

function renderInlineError(message) {
  return message ? `<small class="feedback error">${escapeHtml(message)}</small>` : "";
}

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function syncHighlights() {
  highlightsHidden.value = highlightValues.join(", ");
}

function renderHighlightChips() {
  highlightChipList.innerHTML = "";

  highlightValues.forEach((value) => {
    const chip = document.createElement("span");
    chip.className = "builder-chip";

    const text = document.createElement("span");
    text.textContent = value;

    const removeBtn = document.createElement("button");
    removeBtn.type = "button";
    removeBtn.className = "builder-chip-remove";
    removeBtn.textContent = "✕";
    removeBtn.addEventListener("click", () => {
      highlightValues = highlightValues.filter((item) => item !== value);
      syncHighlights();
      renderHighlightChips();
    });

    chip.appendChild(text);
    chip.appendChild(removeBtn);
    highlightChipList.appendChild(chip);
  });

  syncHighlights();
}

function addHighlightValue() {
  const value = highlightDraftInput.value.trim();
  if (!value || highlightValues.includes(value)) return;
  highlightValues.push(value);
  highlightDraftInput.value = "";
  renderHighlightChips();
}

addVariantBtn?.addEventListener("click", () => {
  variantsState.push(createVariantState());
  renderVariants();
});

addHighlightBtn?.addEventListener("click", addHighlightValue);
highlightDraftInput?.addEventListener("keydown", (event) => {
  if (event.key === "Enter") {
    event.preventDefault();
    addHighlightValue();
  }
});

productNameInput?.addEventListener("input", () => {
  clearStaticFieldError("productName");
});

categorySelect?.addEventListener("change", () => {
  clearStaticFieldError("category");
});

cancelCropBtn?.addEventListener("click", () => {
  closeCropModal();
  renderVariants();
});

applyCropBtn?.addEventListener("click", async () => {
  applyCropBtn.disabled = true;

  try {
    await applyCropAndContinue();
  } finally {
    applyCropBtn.disabled = false;
  }
});

cropModalBackdrop?.addEventListener("click", (event) => {
  if (event.target === cropModalBackdrop) {
    closeCropModal();
    renderVariants();
  }
});

productForm?.addEventListener("submit", (event) => {
  let hasClientValidationError = false;
  let firstInvalidElement = null;

  const productNameValue = String(productNameInput?.value || "").trim();
  const categoryValue = String(categorySelect?.value || "").trim();

  if (!productNameValue) {
    setStaticFieldError("productName", "Product name is required.");
    hasClientValidationError = true;
    firstInvalidElement = firstInvalidElement || productNameInput;
  }

  if (!categoryValue) {
    setStaticFieldError("category", "Category is required.");
    hasClientValidationError = true;
    firstInvalidElement = firstInvalidElement || categorySelect;
  }

  variantsState.forEach((variant, index) => {
    if (!String(variant.size || "").trim()) {
      setTransientFieldError(`variants.${index}.size`, "Size is required.");
      hasClientValidationError = true;
      firstInvalidElement = firstInvalidElement || variantList.querySelector(`[data-variant-input="${index}"][data-field="size"]`);
    }

    if (!String(variant.color || "").trim()) {
      setTransientFieldError(`variants.${index}.color`, "Color is required.");
      hasClientValidationError = true;
      firstInvalidElement = firstInvalidElement || variantList.querySelector(`[data-variant-input="${index}"][data-field="color"]`);
    }

    if (String(variant.price || "").trim() === "") {
      setTransientFieldError(`variants.${index}.price`, "Price is required.");
      hasClientValidationError = true;
      firstInvalidElement = firstInvalidElement || variantList.querySelector(`[data-variant-input="${index}"][data-field="price"]`);
    }

    if (String(variant.stock || "").trim() === "") {
      setTransientFieldError(`variants.${index}.stock`, "Stock is required.");
      hasClientValidationError = true;
      firstInvalidElement = firstInvalidElement || variantList.querySelector(`[data-variant-input="${index}"][data-field="stock"]`);
    }
  });

  const preparedVariants = variantsState.map((variant) => {
    normalizeVariantMainImage(variant);

    const removedImageIndexes = variant.existingImages
      .map((image, index) => image.removed ? index : null)
      .filter((value) => value !== null);

    return {
      size: variant.size,
      color: variant.color,
      price: variant.price,
      offerPrice: variant.offerPrice,
      stock: variant.stock,
      existingImages: variant.existingImages.map((image) => ({
        url: image.url,
        originalUrl: image.originalUrl || image.url,
        cropData: image.cropData || null
      })),
      removedImageIndexes,
      newImagesMeta: variant.newImages.map((image) => ({
        cropData: image.cropData || null
      })),
      mainImageKey: variant.mainImageKey
    };
  });

  const imageError = preparedVariants.findIndex((variant, index) => {
    const existingCount = variant.existingImages.filter((_, imageIndex) => !variant.removedImageIndexes.includes(imageIndex)).length;
    const newCount = variantsState[index].newImages.length;
    return existingCount + newCount < 3;
  });

  if (imageError !== -1) {
    setTransientFieldError(`variants.${imageError}.images`, `Variant ${imageError + 1} needs at least 3 images.`);
    hasClientValidationError = true;
    firstInvalidElement = firstInvalidElement || variantList.querySelector(`[data-variant-file="${imageError}"]`);
  }

  if (hasClientValidationError) {
    event.preventDefault();
    firstInvalidElement?.scrollIntoView({ block: "center", behavior: "smooth" });
    return;
  }

  variantsPayloadInput.value = JSON.stringify(preparedVariants);
});

renderVariants();
renderHighlightChips();
</script>
</body>
</html>
