<!DOCTYPE html>
<html>
<head>
  <title>Offers</title>
  <link rel="stylesheet" href="/css/product-management.css" />
</head>
<body>
<main class="dashboard-scene">
<section class="dashboard-card">
  <%
    const offerFilters = filters || {};
  %>
  <%- include("partials/admin-navbar", { active: "offers" }) %>

  <section class="hero-panel">
    <div class="hero-copy">
      <h1>Offer Module</h1>
      <p>Product offer, category offer, referral offer.</p>
    </div>
  </section>

  <% if (message) { %><p class="feedback success"><%= message %></p><% } %>
  <% if (error) { %><p class="feedback error"><%= error %></p><% } %>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Product Offers</h2>
        <p>Set product offer price or percentage.</p>
      </div>
    </div>

    <div class="controls-form">
      <form method="GET" action="/api/admin/offers" class="search-bar">
        <input type="text" name="productSearch" placeholder="Search product name" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (offerFilters.productSearch) { %>
          <a href="/api/admin/offers?productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&referralSearch=<%= encodeURIComponent(offerFilters.referralSearch || '') %>&referralSort=<%= encodeURIComponent(offerFilters.referralSort || 'newest') %>" class="btn btn-light">Clear</a>
        <% } %>
      </form>

      <form method="GET" action="/api/admin/offers" class="sort-row">
        <label for="productSort">Sort by</label>
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <select id="productSort" name="productSort" class="sort-select">
          <option value="newest" <%= offerFilters.productSort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="oldest" <%= offerFilters.productSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
          <option value="az" <%= offerFilters.productSort === 'az' ? 'selected' : '' %>>A → Z</option>
          <option value="za" <%= offerFilters.productSort === 'za' ? 'selected' : '' %>>Z → A</option>
          <option value="price_low" <%= offerFilters.productSort === 'price_low' ? 'selected' : '' %>>Price Low to High</option>
          <option value="price_high" <%= offerFilters.productSort === 'price_high' ? 'selected' : '' %>>Price High to Low</option>
        </select>
        <button type="submit" class="btn btn-light">Apply Sort</button>
      </form>
    </div>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Base Price</th>
            <th>Offer Price</th>
            <th>Offer %</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <form method="POST" action="/api/admin/offers/products/<%= product._id %>">
                <td><strong><%= product.productName %></strong></td>
                <td>₹<%= product.price %></td>
                <td>
                  <input
                    type="number"
                    name="offerPrice"
                    min="0"
                    value="<%= product.offerPrice || 0 %>"
                    class="search-input"
                  />
                </td>
                <td>
                  <input
                    type="number"
                    name="offerPercentage"
                    min="0"
                    max="90"
                    value="<%= product.offerPercentage || 0 %>"
                    class="search-input"
                  />
                </td>
                <td><button class="btn btn-dark">Save</button></td>
              </form>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Category Offers</h2>
        <p>Largest discount between product and category applies in pricing.</p>
      </div>
    </div>

    <div class="controls-form">
      <form method="GET" action="/api/admin/offers" class="search-bar">
        <input type="text" name="categorySearch" placeholder="Search category name" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (offerFilters.categorySearch) { %>
          <a href="/api/admin/offers?categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&referralSearch=<%= encodeURIComponent(offerFilters.referralSearch || '') %>&referralSort=<%= encodeURIComponent(offerFilters.referralSort || 'newest') %>" class="btn btn-light">Clear</a>
        <% } %>
      </form>

      <form method="GET" action="/api/admin/offers" class="sort-row">
        <label for="categorySort">Sort by</label>
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <select id="categorySort" name="categorySort" class="sort-select">
          <option value="az" <%= offerFilters.categorySort === 'az' ? 'selected' : '' %>>A → Z</option>
          <option value="za" <%= offerFilters.categorySort === 'za' ? 'selected' : '' %>>Z → A</option>
        </select>
        <button type="submit" class="btn btn-light">Apply Sort</button>
      </form>
    </div>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Category</th>
            <th>Offer %</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach((category) => { %>
            <tr>
              <form method="POST" action="/api/admin/offers/categories/<%= category._id %>">
                <td><strong><%= category.name %></strong></td>
                <td>
                  <input
                    type="number"
                    name="offerPercentage"
                    min="0"
                    max="90"
                    value="<%= category.offerPercentage || 0 %>"
                    class="search-input"
                  />
                </td>
                <td><button class="btn btn-dark">Save</button></td>
              </form>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>User Referral Code Control</h2>
        <p>Control user-side profile code display and signup referral usage.</p>
      </div>
    </div>

    <form method="POST" action="/api/admin/offers/referral-control" class="toolbar-grid">
      <select name="signupEnabled">
        <option value="true" <%= referralConfig?.signupEnabled ? 'selected' : '' %>>Referral signup enabled</option>
        <option value="false" <%= !referralConfig?.signupEnabled ? 'selected' : '' %>>Referral signup disabled</option>
      </select>
      <select name="profileVisible">
        <option value="true" <%= referralConfig?.profileVisible ? 'selected' : '' %>>Show user referral code in profile</option>
        <option value="false" <%= !referralConfig?.profileVisible ? 'selected' : '' %>>Hide user referral code in profile</option>
      </select>
      <button class="btn btn-dark" type="submit">Save Referral Control</button>
    </form>

    <form method="POST" action="/api/admin/offers/referral-control/clear-users" style="margin-top:12px;">
      <button class="btn btn-light" type="submit" onclick="return confirm('Clear referral code data for all users?')">Clear All User Referral Codes</button>
    </form>
  </section>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Referral Offers</h2>
        <p>Control running referral campaigns for user referral codes.</p>
      </div>
    </div>

    <div class="controls-form">
      <form method="GET" action="/api/admin/offers" class="search-bar">
        <input type="text" name="referralSearch" placeholder="Search referral title or message" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (offerFilters.referralSearch) { %>
          <a href="/api/admin/offers?referralSort=<%= encodeURIComponent(offerFilters.referralSort || 'newest') %>&productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>" class="btn btn-light">Clear</a>
        <% } %>
      </form>

      <form method="GET" action="/api/admin/offers" class="sort-row">
        <label for="referralSort">Sort by</label>
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <select id="referralSort" name="referralSort" class="sort-select">
          <option value="newest" <%= offerFilters.referralSort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="oldest" <%= offerFilters.referralSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
          <option value="az" <%= offerFilters.referralSort === 'az' ? 'selected' : '' %>>A → Z</option>
          <option value="za" <%= offerFilters.referralSort === 'za' ? 'selected' : '' %>>Z → A</option>
          <option value="reward_low" <%= offerFilters.referralSort === 'reward_low' ? 'selected' : '' %>>Reward Low to High</option>
          <option value="reward_high" <%= offerFilters.referralSort === 'reward_high' ? 'selected' : '' %>>Reward High to Low</option>
        </select>
        <button type="submit" class="btn btn-light">Apply Sort</button>
      </form>
    </div>

    <form method="POST" action="/api/admin/offers/referral" class="toolbar-grid">
      <input name="title" placeholder="Referral title" required />
      <input name="rewardAmount" type="number" min="1" placeholder="Wallet reward amount" required />
      <input name="minPurchase" type="number" min="100" placeholder="Minimum purchase" required />
      <input name="usageLimit" type="number" min="0" placeholder="Usage limit (0 = unlimited)" />
      <input name="message" placeholder="Message for user side" />
      <select name="isActive">
        <option value="true">Active</option>
        <option value="false">Inactive</option>
      </select>
      <button class="btn btn-dark">Create Referral Offer</button>
    </form>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Reward</th>
            <th>Min Purchase</th>
            <th>Usage</th>
            <th>Message</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% referralOffers.forEach((offer) => { %>
            <tr>
              <td><input form="referral-edit-<%= offer._id %>" name="title" value="<%= offer.title %>" class="search-input" required /></td>
              <td><input form="referral-edit-<%= offer._id %>" name="rewardAmount" type="number" min="1" value="<%= offer.rewardAmount %>" class="search-input" required /></td>
              <td><input form="referral-edit-<%= offer._id %>" name="minPurchase" type="number" min="100" value="<%= offer.minPurchase || 100 %>" class="search-input" required /></td>
              <td><%= Number(offer.usedCount || 0) %>/<%= Number(offer.usageLimit || 0) > 0 ? offer.usageLimit : "∞" %><input form="referral-edit-<%= offer._id %>" name="usageLimit" type="number" min="0" value="<%= offer.usageLimit || 0 %>" class="search-input" /></td>
              <td><input form="referral-edit-<%= offer._id %>" name="message" value="<%= offer.message || '' %>" class="search-input" placeholder="Message" /></td>
              <td>
                  <select form="referral-edit-<%= offer._id %>" name="isActive" class="search-input">
                    <option value="true" <%= offer.isActive ? 'selected' : '' %>>Active</option>
                    <option value="false" <%= !offer.isActive ? 'selected' : '' %>>Inactive</option>
                  </select>
              </td>
              <td style="display:flex;gap:8px;">
                  <form id="referral-edit-<%= offer._id %>" method="POST" action="/api/admin/offers/referral/<%= offer._id %>">
                    <button class="btn btn-dark" type="submit">Save</button>
                  </form>
                  <form method="POST" action="/api/admin/offers/referral/<%= offer._id %>/delete">
                    <button class="btn btn-light" type="submit">Delete</button>
                  </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</section>
</main>
</body>
</html>
