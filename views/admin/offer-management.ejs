<!DOCTYPE html>
<html>
<head>
  <title>Offers</title>
  <link rel="stylesheet" href="/css/product-management.css" />
</head>
<body>
<main class="dashboard-scene">
<section class="dashboard-card">
  <%
    const offerFilters = filters || {};
    const sectionPages = paginations || {};
    const productPager = sectionPages.products || { currentPage: 1, totalPages: 1, hasPrev: false, hasNext: false };
    const categoryPager = sectionPages.categories || { currentPage: 1, totalPages: 1, hasPrev: false, hasNext: false };
    const referralPager = sectionPages.referralActivity || { currentPage: 1, totalPages: 1, hasPrev: false, hasNext: false };
  %>
  <%- include("partials/admin-navbar", { active: "offers" }) %>

  <section class="hero-panel">
    <div class="hero-copy">
      <h1>Offer Module</h1>
      <p>Product offer, category offer, referral settings.</p>
    </div>
  </section>

  <% if (message) { %><p class="feedback success"><%= message %></p><% } %>
  <% if (error) { %><p class="feedback error"><%= error %></p><% } %>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Product Offers</h2>
        <p>Set product offer price or percentage.</p>
      </div>
    </div>

    <div class="controls-form">
      <form method="GET" action="/api/admin/offers" class="search-bar">
        <input type="text" name="productSearch" placeholder="Search product name" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (offerFilters.productSearch) { %>
          <a href="/api/admin/offers?productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&referralSearch=<%= encodeURIComponent(offerFilters.referralSearch || '') %>&referralSort=<%= encodeURIComponent(offerFilters.referralSort || 'newest') %>" class="btn btn-light">Clear</a>
        <% } %>
      </form>

      <form method="GET" action="/api/admin/offers" class="sort-row">
        <label for="productSort">Sort by</label>
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <select id="productSort" name="productSort" class="sort-select">
          <option value="newest" <%= offerFilters.productSort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="oldest" <%= offerFilters.productSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
          <option value="az" <%= offerFilters.productSort === 'az' ? 'selected' : '' %>>A → Z</option>
          <option value="za" <%= offerFilters.productSort === 'za' ? 'selected' : '' %>>Z → A</option>
          <option value="price_low" <%= offerFilters.productSort === 'price_low' ? 'selected' : '' %>>Price Low to High</option>
          <option value="price_high" <%= offerFilters.productSort === 'price_high' ? 'selected' : '' %>>Price High to Low</option>
        </select>
        <button type="submit" class="btn btn-light">Apply Sort</button>
      </form>
    </div>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Base Price</th>
            <th>Offer Price</th>
            <th>Offer %</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <form method="POST" action="/api/admin/offers/products/<%= product._id %>">
                <td><strong><%= product.productName %></strong></td>
                <td>₹<%= product.price %></td>
                <td>
                  <input
                    type="number"
                    name="offerPrice"
                    min="0"
                    value="<%= product.offerPrice || 0 %>"
                    class="search-input"
                  />
                </td>
                <td>
                  <input
                    type="number"
                    name="offerPercentage"
                    min="0"
                    max="90"
                    value="<%= product.offerPercentage || 0 %>"
                    class="search-input"
                  />
                </td>
                <td><button class="btn btn-dark">Save</button></td>
              </form>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (productPager.totalPages > 1) { %>
      <div class="pagination">
        <% if (productPager.hasPrev) { %>
          <a class="page-btn" href="/api/admin/offers?productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productPage=<%= productPager.currentPage - 1 %>&categoryPage=<%= categoryPager.currentPage %>&referralPage=<%= referralPager.currentPage %>">Prev</a>
        <% } %>
        <span class="page-btn active"><%= productPager.currentPage %></span>
        <% if (productPager.hasNext) { %>
          <a class="page-btn" href="/api/admin/offers?productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productPage=<%= productPager.currentPage + 1 %>&categoryPage=<%= categoryPager.currentPage %>&referralPage=<%= referralPager.currentPage %>">Next</a>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Category Offers</h2>
        <p>Largest discount between product and category applies in pricing.</p>
      </div>
    </div>

    <div class="controls-form">
      <form method="GET" action="/api/admin/offers" class="search-bar">
        <input type="text" name="categorySearch" placeholder="Search category name" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="categorySort" value="<%= offerFilters.categorySort || 'az' %>" />
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (offerFilters.categorySearch) { %>
          <a href="/api/admin/offers?categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&referralSearch=<%= encodeURIComponent(offerFilters.referralSearch || '') %>&referralSort=<%= encodeURIComponent(offerFilters.referralSort || 'newest') %>" class="btn btn-light">Clear</a>
        <% } %>
      </form>

      <form method="GET" action="/api/admin/offers" class="sort-row">
        <label for="categorySort">Sort by</label>
        <input type="hidden" name="categorySearch" value="<%= offerFilters.categorySearch || '' %>" />
        <input type="hidden" name="productSearch" value="<%= offerFilters.productSearch || '' %>" />
        <input type="hidden" name="productSort" value="<%= offerFilters.productSort || 'newest' %>" />
        <input type="hidden" name="referralSearch" value="<%= offerFilters.referralSearch || '' %>" />
        <input type="hidden" name="referralSort" value="<%= offerFilters.referralSort || 'newest' %>" />
        <select id="categorySort" name="categorySort" class="sort-select">
          <option value="az" <%= offerFilters.categorySort === 'az' ? 'selected' : '' %>>A → Z</option>
          <option value="za" <%= offerFilters.categorySort === 'za' ? 'selected' : '' %>>Z → A</option>
        </select>
        <button type="submit" class="btn btn-light">Apply Sort</button>
      </form>
    </div>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Category</th>
            <th>Offer %</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach((category) => { %>
            <tr>
              <form method="POST" action="/api/admin/offers/categories/<%= category._id %>">
                <td><strong><%= category.name %></strong></td>
                <td>
                  <input
                    type="number"
                    name="offerPercentage"
                    min="0"
                    max="90"
                    value="<%= category.offerPercentage || 0 %>"
                    class="search-input"
                  />
                </td>
                <td><button class="btn btn-dark">Save</button></td>
              </form>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (categoryPager.totalPages > 1) { %>
      <div class="pagination">
        <% if (categoryPager.hasPrev) { %>
          <a class="page-btn" href="/api/admin/offers?productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productPage=<%= productPager.currentPage %>&categoryPage=<%= categoryPager.currentPage - 1 %>&referralPage=<%= referralPager.currentPage %>">Prev</a>
        <% } %>
        <span class="page-btn active"><%= categoryPager.currentPage %></span>
        <% if (categoryPager.hasNext) { %>
          <a class="page-btn" href="/api/admin/offers?productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productPage=<%= productPager.currentPage %>&categoryPage=<%= categoryPager.currentPage + 1 %>&referralPage=<%= referralPager.currentPage %>">Next</a>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Referral Settings</h2>
        <p>One global referral system for signup and first successful order rewards.</p>
      </div>
    </div>

    <form method="POST" action="/api/admin/offers/referral-settings" class="toolbar-grid">
      <input
        name="referrerReward"
        type="number"
        min="0"
        placeholder="Referrer reward"
        value="<%= Number(referralSettings?.referrerReward || 0) %>"
        required
      />
      <input
        name="newUserReward"
        type="number"
        min="0"
        placeholder="New user reward"
        value="<%= Number(referralSettings?.newUserReward || 0) %>"
        required
      />
      <input
        name="minimumPurchase"
        type="number"
        min="100"
        placeholder="Minimum purchase"
        value="<%= Number(referralSettings?.minimumPurchase || 100) %>"
        required
      />
      <select name="referralEnabled">
        <option value="true" <%= referralSettings?.referralEnabled ? 'selected' : '' %>>Referral enabled</option>
        <option value="false" <%= !referralSettings?.referralEnabled ? 'selected' : '' %>>Referral disabled</option>
      </select>
      <select name="referralDisplayEnabled">
        <option value="true" <%= referralSettings?.referralDisplayEnabled !== false ? 'selected' : '' %>>Show code and link to users</option>
        <option value="false" <%= referralSettings?.referralDisplayEnabled === false ? 'selected' : '' %>>Hide code and link from users</option>
      </select>
      <button class="btn btn-dark" type="submit">Save Referral Settings</button>
    </form>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Setting</th>
            <th>Current Value</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Referrer reward</strong></td>
            <td>₹<%= Number(referralSettings?.referrerReward || 0).toLocaleString("en-IN") %></td>
          </tr>
          <tr>
            <td><strong>New user reward</strong></td>
            <td>₹<%= Number(referralSettings?.newUserReward || 0).toLocaleString("en-IN") %></td>
          </tr>
          <tr>
            <td><strong>Minimum purchase</strong></td>
            <td>₹<%= Number(referralSettings?.minimumPurchase || 100).toLocaleString("en-IN") %></td>
          </tr>
          <tr>
            <td><strong>Status</strong></td>
            <td><%= referralSettings?.referralEnabled ? "Enabled" : "Disabled" %></td>
          </tr>
          <tr>
            <td><strong>Code and link display</strong></td>
            <td><%= referralSettings?.referralDisplayEnabled === false ? "Hidden" : "Visible" %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="content-panel">
    <div class="panel-head">
      <div>
        <h2>Referral Activity</h2>
        <p>Admin can see who referred who and reward status.</p>
      </div>
    </div>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>New User</th>
            <th>Referred By</th>
            <th>Referrer Reward</th>
            <th>New User Reward</th>
            <th>Status</th>
            <th>Order</th>
          </tr>
        </thead>
        <tbody>
          <% if (!referralActivity || !referralActivity.length) { %>
            <tr>
              <td colspan="6">No referral activity yet.</td>
            </tr>
          <% } %>
          <% (referralActivity || []).forEach((item) => { %>
            <tr>
              <td>
                <strong><%= item.name %></strong><br />
                <span><%= item.email %></span>
              </td>
              <td>
                <% if (item.referredBy) { %>
                  <strong><%= item.referredBy.name %></strong><br />
                  <span><%= item.referredBy.email %></span>
                <% } else { %>
                  --
                <% } %>
              </td>
              <td>₹<%= Number(item.referrerRewardGranted || 0).toLocaleString("en-IN") %></td>
              <td>₹<%= Number(item.newUserRewardGranted || 0).toLocaleString("en-IN") %></td>
              <td><%= item.referralRewardClaimed ? "Rewarded" : "Pending first order" %></td>
              <td>
                <% if (item.referralRewardOrder?.orderId) { %>
                  <strong><%= item.referralRewardOrder.orderId %></strong><br />
                  <span>₹<%= Number(item.referralRewardOrder.grandTotal || 0).toLocaleString("en-IN") %></span>
                <% } else { %>
                  --
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (referralPager.totalPages > 1) { %>
      <div class="pagination">
        <% if (referralPager.hasPrev) { %>
          <a class="page-btn" href="/api/admin/offers?productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productPage=<%= productPager.currentPage %>&categoryPage=<%= categoryPager.currentPage %>&referralPage=<%= referralPager.currentPage - 1 %>">Prev</a>
        <% } %>
        <span class="page-btn active"><%= referralPager.currentPage %></span>
        <% if (referralPager.hasNext) { %>
          <a class="page-btn" href="/api/admin/offers?productSearch=<%= encodeURIComponent(offerFilters.productSearch || '') %>&productSort=<%= encodeURIComponent(offerFilters.productSort || 'newest') %>&categorySearch=<%= encodeURIComponent(offerFilters.categorySearch || '') %>&categorySort=<%= encodeURIComponent(offerFilters.categorySort || 'az') %>&productPage=<%= productPager.currentPage %>&categoryPage=<%= categoryPager.currentPage %>&referralPage=<%= referralPager.currentPage + 1 %>">Next</a>
        <% } %>
      </div>
    <% } %>
  </section>
</section>
</main>
</body>
</html>
