<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Management</title>
<link rel="stylesheet" href="/css/admin-usermanagement.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body>

<main class="neo-scene">
<section class="neo-card">

<%- include("partials/admin-navbar", { active: "users" }) %>

<section class="panel">

<div class="panel-head">
<h1>User Management</h1>
<p>Search and manage customer accounts</p>
</div>

<form method="GET" action="/api/admin/adminusermanagement" class="search-section">
<input
type="text"
name="search"
placeholder="Search by name or email"
value="<%= search || '' %>"
>
<button type="submit" class="btn btn-dark">Apply</button>

<% if (search) { %>
<a href="/api/admin/adminusermanagement" class="btn btn-light">Clear</a>
<% } %>
</form>

<div class="table-wrap">

<table class="user-table">

<thead>
<tr>
<th>Name</th>
<th>Email</th>
<th>Status</th>

<% if (admin && admin.role === "superadmin") { %>
<th>Role</th>
<% } %>

<th>Total</th>
<th>Referral Code</th>
<th>Referral</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<% if (users.length === 0) { %>
<tr>
<td colspan="<%= admin && admin.role === 'superadmin' ? 8 : 7 %>" class="empty-cell">No users found</td>
</tr>
<% } %>

<% users.forEach(user => { %>
<tr>

<td><%= user.name %></td>
<td><%= user.email %></td>

<td>
<% if (!user.isBlocked) { %>
<span class="status active">Active</span>
<% } else { %>
<span class="status blocked">Blocked</span>
<% } %>
</td>

<% if (admin && admin.role === "superadmin") { %>
<td><%= user.role %></td>
<% } %>

<td>₹0</td>

<td><%= user.referralCode || '--' %></td>

<td>
  <% if (user.referralSuspended) { %>
    <span class="status blocked">Suspended</span>
  <% } else { %>
    <span class="status active">Enabled</span>
  <% } %>
</td>

<td>
<div class="action-row">

  <% if (admin && (admin.role === "admin" || admin.role === "superadmin")) { %>
    <% if (!user.isBlocked) { %>
      <form action="/api/admin/adminusermanagement/block/<%= user._id %>" method="POST" class="js-confirm-form" data-confirm-title="Block User" data-confirm-message="Block this user?">
        <button class="btn btn-danger" type="submit">Block</button>
      </form>
    <% } else { %>
      <form action="/api/admin/adminusermanagement/unblock/<%= user._id %>" method="POST" class="js-confirm-form" data-confirm-title="Unblock User" data-confirm-message="Unblock this user?">
        <button class="btn btn-success" type="submit">Unblock</button>
      </form>
    <% } %>
  <% } %>

  <% if (admin && admin.role === "superadmin") { %>
    <% if (user.role === "user") { %>
      <form action="/api/admin/makeadmin/<%= user._id %>" method="POST" class="js-confirm-form" data-confirm-title="Make Admin" data-confirm-message="Promote this user to admin?">
        <button class="btn btn-dark" type="submit">Make Admin</button>
      </form>
    <% } %>

    <% if (user.role === "admin") { %>
      <form action="/api/admin/removeadmin/<%= user._id %>" method="POST" class="js-confirm-form" data-confirm-title="Remove Admin" data-confirm-message="Remove admin privileges?">
        <button class="btn btn-light" type="submit">Remove Admin</button>
      </form>
    <% } %>
  <% } %>

  <form action="/api/admin/adminusermanagement/referral/<%= user._id %>/reset" method="POST" class="js-confirm-form" data-confirm-title="Reset Referral State" data-confirm-message="Reset referral reward state for this user?">
    <button class="btn btn-light" type="submit">Reset State</button>
  </form>

  <form action="/api/admin/adminusermanagement/referral/<%= user._id %>/regenerate" method="POST" class="js-confirm-form" data-confirm-title="Regenerate Referral Code" data-confirm-message="Regenerate referral code for this user?">
    <button class="btn btn-dark" type="submit">Regen Code</button>
  </form>

  <% if (!user.referralSuspended) { %>
    <form action="/api/admin/adminusermanagement/referral/<%= user._id %>/suspend" method="POST" class="js-confirm-form" data-confirm-title="Suspend Referral" data-confirm-message="Suspend referral account for this user?">
      <button class="btn btn-danger" type="submit">Suspend Ref</button>
    </form>
  <% } else { %>
    <form action="/api/admin/adminusermanagement/referral/<%= user._id %>/resume" method="POST" class="js-confirm-form" data-confirm-title="Resume Referral" data-confirm-message="Resume referral account for this user?">
      <button class="btn btn-success" type="submit">Resume Ref</button>
    </form>
  <% } %>

</div>
</td>

</tr>
<% }) %>

</tbody>

</table>

</div>

<% if (typeof totalPages !== "undefined" && totalPages > 1) { %>
<div class="pagination">

<% if (currentPage > 1) { %>
<a
class="page-btn"
href="/api/admin/adminusermanagement?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
>Prev</a>
<% } %>

<% paginationItems.forEach(i => { %>
<a
class="page-btn <%= i === currentPage ? 'active' : '' %>"
href="/api/admin/adminusermanagement?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
><%= i %></a>
<% }) %>

<% if (currentPage < totalPages) { %>
<a
class="page-btn"
href="/api/admin/adminusermanagement?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
>Next</a>
<% } %>

</div>
<% } %>

</section>
</section>
</main>

<div class="admin-modal-backdrop" id="adminConfirmModal" aria-hidden="true">
  <div class="admin-modal-box" role="dialog" aria-modal="true" aria-labelledby="adminConfirmTitle">
    <h3 id="adminConfirmTitle">Confirm Action</h3>
    <p id="adminConfirmText">Are you sure?</p>
    <div class="admin-modal-actions">
      <button type="button" class="btn btn-light" id="adminConfirmCancel">Cancel</button>
      <button type="button" class="btn btn-dark" id="adminConfirmProceed">Confirm</button>
    </div>
  </div>
</div>

<script>
window.addEventListener("pageshow", function (e) {
  if (e.persisted) {
    location.reload();
  }
});

(() => {
  const modal = document.getElementById("adminConfirmModal");
  const titleEl = document.getElementById("adminConfirmTitle");
  const textEl = document.getElementById("adminConfirmText");
  const cancelBtn = document.getElementById("adminConfirmCancel");
  const proceedBtn = document.getElementById("adminConfirmProceed");
  let pendingForm = null;

  const openModal = (form) => {
    pendingForm = form;
    titleEl.textContent = form.dataset.confirmTitle || "Confirm Action";
    textEl.textContent = form.dataset.confirmMessage || "Are you sure you want to continue?";
    modal.classList.add("show");
    modal.setAttribute("aria-hidden", "false");
  };

  const closeModal = () => {
    pendingForm = null;
    modal.classList.remove("show");
    modal.setAttribute("aria-hidden", "true");
  };

  document.querySelectorAll(".js-confirm-form").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      openModal(form);
    });
  });

  cancelBtn?.addEventListener("click", closeModal);
  proceedBtn?.addEventListener("click", () => {
    if (pendingForm) pendingForm.submit();
  });
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && modal.classList.contains("show")) {
      closeModal();
    }
  });
})();
</script>

</body>
</html>
