<!DOCTYPE html>
<html>
<head>
  <title>User Management</title>
  <link rel="stylesheet" href="/css/admin-usermanagement.css">
</head>
<body>

<header class="admin-header">
  <div class="logo">NIKE</div>
  <nav>
    <a href="/api/admin/dashboard">Dashboard</a>
    <a href="/api/admin/products">Products</a>
    <a href="/api/admin/categories">Categories</a>
    <a href="/api/admin/orders">Orders</a>
    <a href="/api/admin/adminusermanagement">Users</a>
    <a href="/api/admin/adminlogout">Logout</a>
  </nav>
</header>

<div class="container">

  <h1>User Management</h1>

  <!-- SEARCH SECTION -->
  <form method="GET" action="/api/admin/adminusermanagement" class="search-section">
    <input 
      type="text" 
      name="search" 
      placeholder="Search"
      value="<%= search || '' %>"
    >

    <button type="submit">Apply</button>

    <% if (search) { %>
      <a href="/api/admin/adminusermanagement" class="clear-btn">Clear</a>
    <% } %>
  </form>

  <!-- USER TABLE -->
  <table class="user-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Status</th>
        <th>Total</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if (users.length === 0) { %>
        <tr>
          <td colspan="5" style="text-align:center;">No users found</td>
        </tr>
      <% } %>

      <% users.forEach(user => { %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>

          <td>
            <% if (!user.isBlocked) { %>
              <span class="status active">Active</span>
            <% } else { %>
              <span class="status blocked">Blocked</span>
            <% } %>
          </td>

          <td>0</td>

          <td>
            <% if (!user.isBlocked) { %>

              <form 
                action="/api/admin/adminusermanagement/block/<%= user._id %>" 
                method="POST"
                onsubmit="return confirm('Are you sure you want to block this user?')"
              >
                <button type="submit" class="btn block">Block</button>
              </form>

            <% } else { %>

              <form 
                action="/api/admin/adminusermanagement/unblock/<%= user._id %>" 
                method="POST"
                onsubmit="return confirm('Are you sure you want to unblock this user?')"
              >
                <button type="submit" class="btn unblock">Unblock</button>
              </form>

            <% } %>
          </td>

        </tr>
      <% }) %>

    </tbody>
  </table>

</div>

</body>
</html>