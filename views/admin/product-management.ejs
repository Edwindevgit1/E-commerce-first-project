<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Management</title>

  <link rel="stylesheet" href="/css/product-management.css" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>

<body>

<main class="dashboard-scene">
<section class="dashboard-card">

<header class="top-strip">

<div class="chip-row">
<a href="/api/admin/dashboard" class="chip">Dashboard</a>
<a href="/api/admin/products" class="chip chip-dark">Products</a>
<a href="/api/admin/category" class="chip">Categories</a>
<a href="/api/admin/orders" class="chip">Orders</a>
<a href="/api/admin/adminusermanagement" class="chip">Users</a>
</div>

<form action="/api/admin/adminlogout" method="POST">
<button type="submit" class="logout-pill">Logout</button>
</form>

</header>


<section class="hero-panel">

<div class="hero-copy">
<h1>Product Management</h1>
<p>Manage the product catalog with search, filters, edit actions, and soft delete.</p>
</div>

<div class="hero-stats">

<article class="stat-card">
<span>Total Products</span>
<strong><%= totalProducts || 0 %></strong>
</article>

<article class="stat-card">
<span>Current Page</span>
<strong><%= currentPage || 1 %></strong>
</article>

</div>

</section>



<section class="content-panel">

<div class="panel-head">

<div>
<h2>Product List</h2>
<p>Search products first, then narrow by category or status.</p>
</div>

<a href="/api/admin/add-product" class="btn btn-dark">
Add Product
</a>

</div>



<% if (error) { %>
<p class="feedback error"><%= error %></p>
<% } %>



<form method="GET" action="/api/admin/products" class="toolbar-grid">

<input
type="text"
name="search"
class="search-input"
placeholder="Search products"
value="<%= search || '' %>"
/>

<select name="category" class="toolbar-select">

<option value="">All Categories</option>

<% categories.forEach((category)=>{ %>

<option
value="<%= category._id %>"
<%= String(selectedCategory) === String(category._id) ? "selected" : "" %>
>
<%= category.name %>
</option>

<% }) %>

</select>



<select name="status" class="toolbar-select">

<option value="">All Status</option>

<option value="active" <%= selectedStatus === "active" ? "selected" : "" %>>
Active
</option>

<option value="inactive" <%= selectedStatus === "inactive" ? "selected" : "" %>>
Inactive
</option>

</select>

<button type="submit" class="btn btn-dark">
Search
</button>

<a href="/api/admin/products" class="btn btn-light">
Clear
</a>

</form>



<div class="table-wrap">

<table class="product-table">

<thead>

<tr>
<th>#</th>
<th>Image</th>
<th>Name</th>
<th>Category</th>
<th>Price</th>
<th>Stock</th>
<th>Status</th>
<th>Actions</th>
</tr>

</thead>


<tbody>

<% if (!products || products.length === 0) { %>

<tr>
<td colspan="8" class="empty-cell">
No products found yet.
</td>
</tr>

<% } else { %>

<% products.forEach((product,index)=>{ %>

<tr>

<td>
<%= ((currentPage - 1) * (limit || 10)) + index + 1 %>
</td>


<td>

<div class="thumb-shell">

<img
src="<%= product.images && product.images.length ? product.images[product.mainImageIndex || 0] || product.images[0] : 'https://placehold.co/90x64?text=Item' %>"
alt="<%= product.productName %>"
class="product-thumb"
/>

</div>

</td>


<td>

<div class="product-name">

<strong>
<%= product.productName %>
</strong>

<span>
<%= product.description || "Catalog item" %>
</span>

</div>

</td>


<td>
<%= product.category?.name || "--" %>
</td>


<td>
₹<%= product.price %>
</td>


<td>
<%= product.stock %>
</td>


<td>

<span class="status-badge <%= product.status === 'active' ? 'active' : 'inactive' %>">

<%= product.status %>

</span>

</td>


<td>

<div class="action-row">

<a
href="/api/admin/edit-product/<%= product._id %>"
class="icon-btn edit-btn"
title="Edit"
>
✏
</a>

<button
type="button"
class="icon-btn delete-btn open-delete-modal"
data-id="<%= product._id %>"
data-name="<%= product.productName %>"
title="Soft Delete"
>
🗑
</button>

</div>

</td>

</tr>

<% }) %>

<% } %>

</tbody>

</table>

</div>



<div class="pagination">
<% if ((totalPages || 1) > 1) { %>

<% if (currentPage > 1) { %>
<a
class="page-btn"
href="/api/admin/products?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category=' + encodeURIComponent(selectedCategory) : '' %><%= selectedStatus ? '&status=' + encodeURIComponent(selectedStatus) : '' %>"
>Prev</a>
<% } %>

<% paginationItems.forEach(i => { %>
<a
class="page-btn <%= i === currentPage ? 'active' : '' %>"
href="/api/admin/products?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category=' + encodeURIComponent(selectedCategory) : '' %><%= selectedStatus ? '&status=' + encodeURIComponent(selectedStatus) : '' %>"
><%= i %></a>
<% }) %>

<% if (currentPage < totalPages) { %>
<a
class="page-btn"
href="/api/admin/products?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category=' + encodeURIComponent(selectedCategory) : '' %><%= selectedStatus ? '&status=' + encodeURIComponent(selectedStatus) : '' %>"
>Next</a>
<% } %>

<% } %>

</div>

</section>

</section>
</main>



<div class="modal-backdrop" id="deleteModal">

<div class="modal-box">

<h3>Soft Delete Product</h3>

<p id="deleteProductText">
Are you sure you want to soft delete this product?
</p>

<form id="deleteProductForm" method="POST">

<div class="modal-actions">

<button type="button" class="btn btn-light close-delete-modal">
Cancel
</button>

<button type="submit" class="btn btn-danger">
OK, Delete
</button>

</div>

</form>

</div>

</div>



<script>

const deleteModal=document.getElementById("deleteModal");

const deleteProductForm=document.getElementById("deleteProductForm");

const deleteProductText=document.getElementById("deleteProductText");



document.querySelectorAll(".open-delete-modal").forEach(button=>{

button.addEventListener("click",()=>{

deleteProductForm.action=`/api/admin/delete-product/${button.dataset.id}`;

deleteProductText.textContent=
`Are you sure you want to soft delete "${button.dataset.name}"?`;

deleteModal.classList.add("show");

});

});



document.querySelectorAll(".close-delete-modal").forEach(button=>{

button.addEventListener("click",()=>{

deleteModal.classList.remove("show");

});

});



deleteModal.addEventListener("click",(event)=>{

if(event.target===deleteModal){

deleteModal.classList.remove("show");

}

});

</script>


</body>
</html>
