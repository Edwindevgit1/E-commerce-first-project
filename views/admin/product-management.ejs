<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Management</title>

  <link rel="stylesheet" href="/css/product-management.css" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>

<body>

<main class="dashboard-scene">
<section class="dashboard-card">

<%- include("partials/admin-navbar", { active: "products" }) %>


<section class="hero-panel">

<div class="hero-copy">
<h1>Product Management</h1>
<p>Manage the product catalog with search, filters, edit actions, and soft delete.</p>
</div>

<div class="hero-stats">

<article class="stat-card">
<span>Total Products</span>
<strong><%= totalProducts || 0 %></strong>
</article>

<article class="stat-card">
<span>Current Page</span>
<strong><%= currentPage || 1 %></strong>
</article>

</div>

</section>



<section class="content-panel">

<div class="panel-head">

<div>
<h2>Product List</h2>
<p>Search products first, then narrow by category or status.</p>
</div>

<a href="/api/admin/add-product" class="btn btn-dark">
Add Product
</a>

</div>



<% if (error) { %>
<p class="feedback error"><%= error %></p>
<% } %>



<form method="GET" action="/api/admin/products" class="toolbar-grid">

<input
type="text"
name="search"
class="search-input"
placeholder="Search products"
value="<%= search || '' %>"
/>

<select name="category" class="toolbar-select">

<option value="">All Categories</option>

<% categories.forEach((category)=>{ %>

<option
value="<%= category._id %>"
<%= String(selectedCategory) === String(category._id) ? "selected" : "" %>
>
<%= category.name %>
</option>

<% }) %>

</select>



<select name="status" class="toolbar-select">

<option value="">All Status</option>

<option value="active" <%= selectedStatus === "active" ? "selected" : "" %>>
Active
</option>

<option value="inactive" <%= selectedStatus === "inactive" ? "selected" : "" %>>
Inactive
</option>

<option value="soft_deleted" <%= selectedStatus === "soft_deleted" ? "selected" : "" %>>
Soft Deleted
</option>

</select>

<select name="stock" class="toolbar-select">
<option value="">All Stock</option>
<option value="in_stock" <%= selectedStock === "in_stock" ? "selected" : "" %>>
In Stock
</option>
<option value="low_stock" <%= selectedStock === "low_stock" ? "selected" : "" %>>
Low Stock
</option>
<option value="out_of_stock" <%= selectedStock === "out_of_stock" ? "selected" : "" %>>
Out of Stock
</option>
</select>

<button type="submit" class="btn btn-dark">
Search
</button>

<a href="/api/admin/products" class="btn btn-light">
Clear
</a>

</form>



<div class="table-wrap">

<table class="product-table">

<thead>

<tr>
<th>#</th>
<th>Image</th>
<th>Name</th>
<th>Category</th>
<th>Price</th>
<th>Stock</th>
<th>Status</th>
<th>Actions</th>
</tr>

</thead>


<tbody>

<% if (!products || products.length === 0) { %>

<tr>
<td colspan="8" class="empty-cell">
No products found yet.
</td>
</tr>

<% } else { %>

<% products.forEach((product,index)=>{ %>
<% const categoryInactive = product.category && product.category.status !== "active"; %>
<% const categoryDeleted = !product.category || product.category.isDeleted; %>
<% const isSoftDeleted = product.isDeleted === true; %>
<% const productInactive = product.status !== "active"; %>
<% const productUnavailable = isSoftDeleted || productInactive || categoryInactive || categoryDeleted; %>

<tr class="<%= productUnavailable ? 'product-row--unavailable' : '' %>">

<td>
<%= ((currentPage - 1) * (limit || 10)) + index + 1 %>
</td>


<td>

<div class="thumb-shell">

<img
src="<%= product.images && product.images.length ? product.images[product.mainImageIndex || 0] || product.images[0] : 'https://placehold.co/90x64?text=Item' %>"
alt="<%= product.productName %>"
class="product-thumb"
/>

</div>

</td>


<td>

<div class="product-name">

<strong>
<%= product.productName %>
</strong>

<span>
<%= product.description || "Catalog item" %>
</span>

</div>

</td>


<td>
<div class="product-category-cell">
<strong><%= product.category?.name || "--" %></strong>
<% if (categoryDeleted) { %>
<span class="category-availability-note">Category deleted</span>
<% } else if (categoryInactive) { %>
<span class="category-availability-note">Category inactive</span>
<% } %>
</div>
</td>


<td>
₹<%= product.price %>
</td>


<td>
<%= product.stock %>
</td>


<td>
<div class="status-stack">
<span class="status-badge <%= isSoftDeleted ? 'soft-deleted' : product.status === 'active' ? 'active' : 'inactive' %>">
<%= isSoftDeleted ? 'soft deleted' : product.status %>
</span>
<% if (!isSoftDeleted && !productInactive && categoryDeleted) { %>
<span class="status-badge category-warning">Unavailable</span>
<% } else if (!isSoftDeleted && !productInactive && categoryInactive) { %>
<span class="status-badge category-warning">Temporarily unavailable</span>
<% } %>
</div>
</td>


<td>

<div class="action-row">

<% if (isSoftDeleted) { %>
<button
type="button"
class="btn btn-dark open-restore-action-modal"
data-id="<%= product._id %>"
data-name="<%= product.productName %>"
title="Make Active Again"
>
Restore
</button>
<% } else { %>
<a
href="/api/admin/edit-product/<%= product._id %>"
class="icon-btn edit-btn"
title="Edit"
>
✏
</a>
<% } %>

<button
type="button"
class="icon-btn delete-btn open-delete-modal"
data-id="<%= product._id %>"
data-name="<%= product.productName %>"
title="Delete Options"
>
🗑
</button>

</div>

</td>

</tr>

<% }) %>

<% } %>

</tbody>

</table>

</div>



<div class="pagination">
<% if ((totalPages || 1) > 1) { %>

<% if (currentPage > 1) { %>
<a
class="page-btn"
href="/api/admin/products?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category=' + encodeURIComponent(selectedCategory) : '' %><%= selectedStatus ? '&status=' + encodeURIComponent(selectedStatus) : '' %><%= selectedStock ? '&stock=' + encodeURIComponent(selectedStock) : '' %>"
>Prev</a>
<% } %>

<% paginationItems.forEach(i => { %>
<a
class="page-btn <%= i === currentPage ? 'active' : '' %>"
href="/api/admin/products?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category=' + encodeURIComponent(selectedCategory) : '' %><%= selectedStatus ? '&status=' + encodeURIComponent(selectedStatus) : '' %><%= selectedStock ? '&stock=' + encodeURIComponent(selectedStock) : '' %>"
><%= i %></a>
<% }) %>

<% if (currentPage < totalPages) { %>
<a
class="page-btn"
href="/api/admin/products?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category=' + encodeURIComponent(selectedCategory) : '' %><%= selectedStatus ? '&status=' + encodeURIComponent(selectedStatus) : '' %><%= selectedStock ? '&stock=' + encodeURIComponent(selectedStock) : '' %>"
>Next</a>
<% } %>

<% } %>

</div>

</section>

</section>
</main>

<% if (restorePrompt) { %>
<div class="modal-backdrop show" id="restoreProductModal">
  <div class="modal-box">
    <h3>Restore Product?</h3>
    <p>
      The product "<%= restorePrompt.name %>" was deleted previously.
      Do you want to make it available again?
    </p>

    <div class="modal-actions">
      <form action="/api/admin/restore-product/<%= restorePrompt.id %>" method="POST">
        <button type="submit" class="btn btn-dark">Yes, Restore</button>
      </form>

      <a href="/api/admin/products" class="btn btn-light">Cancel</a>
    </div>
  </div>
</div>
<% } %>


<div class="modal-backdrop" id="restoreActionModal">
  <div class="modal-box">
    <h3>Restore Product</h3>

    <p id="restoreActionText">
      Are you sure you want to restore this product?
    </p>

    <form id="restoreActionForm" method="POST">
      <div class="modal-actions">
        <button type="button" class="btn btn-light close-restore-action-modal">
          Cancel
        </button>

        <button type="submit" class="btn btn-dark">
          Yes, Restore
        </button>
      </div>
    </form>
  </div>
</div>



<div class="modal-backdrop" id="deleteModal">

<div class="modal-box">

<h3>Delete Product</h3>

<p id="deleteProductText">
Choose how you want to remove this product.
</p>

<form id="deleteProductForm" method="POST">

<div class="modal-actions">

<button type="button" class="btn btn-light close-delete-modal">
Cancel
</button>

<button type="submit" class="btn btn-light" id="softDeleteProductButton">
Soft Delete
</button>

<button type="submit" class="btn btn-danger" id="permanentDeleteProductButton">
Permanent Delete
</button>

</div>

</form>

</div>

</div>



<script>

window.addEventListener("pageshow", function (event) {
  if (event.persisted) {
    window.location.reload();
  }
});

const deleteModal=document.getElementById("deleteModal");

const deleteProductForm=document.getElementById("deleteProductForm");

const deleteProductText=document.getElementById("deleteProductText");
const restoreActionModal = document.getElementById("restoreActionModal");
const restoreActionForm = document.getElementById("restoreActionForm");
const restoreActionText = document.getElementById("restoreActionText");



document.querySelectorAll(".open-restore-action-modal").forEach(button=>{

button.addEventListener("click",()=>{

restoreActionForm.action=`/api/admin/restore-product/${button.dataset.id}`;

restoreActionText.textContent=
`Are you sure you want to restore "${button.dataset.name}"?`;

restoreActionModal.classList.add("show");

});

});



document.querySelectorAll(".close-restore-action-modal").forEach(button=>{

button.addEventListener("click",()=>{

restoreActionModal.classList.remove("show");

});

});



restoreActionModal?.addEventListener("click",(event)=>{

if(event.target===restoreActionModal){

restoreActionModal.classList.remove("show");

}

});



document.querySelectorAll(".open-delete-modal").forEach(button=>{

button.addEventListener("click",()=>{

deleteProductForm.dataset.productId = button.dataset.id;
deleteProductForm.action=`/api/admin/delete-product/${button.dataset.id}`;

deleteProductText.textContent=
`Choose whether to soft delete or permanently delete "${button.dataset.name}".`;

deleteModal.classList.add("show");

});

});



document.querySelectorAll(".close-delete-modal").forEach(button=>{

button.addEventListener("click",()=>{

deleteModal.classList.remove("show");

});

});



deleteModal.addEventListener("click",(event)=>{

if(event.target===deleteModal){

deleteModal.classList.remove("show");

}

});

const softDeleteProductButton = document.getElementById("softDeleteProductButton");
const permanentDeleteProductButton = document.getElementById("permanentDeleteProductButton");

softDeleteProductButton?.addEventListener("click", () => {
  const action = deleteProductForm.dataset.productId;
  if (!action) return;
  deleteProductForm.action = `/api/admin/delete-product/${action}`;
});

permanentDeleteProductButton?.addEventListener("click", () => {
  const action = deleteProductForm.dataset.productId;
  if (!action) return;
  deleteProductForm.action = `/api/admin/permanent-delete-product/${action}`;
});

const restoreProductModal = document.getElementById("restoreProductModal");

restoreProductModal?.addEventListener("click",(event)=>{

if(event.target===restoreProductModal){

window.location.href="/api/admin/products";

}

});

</script>

</body>
</html>
