<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Detail</title>
  <link rel="stylesheet" href="/css/product-management.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <style>
    .detail-grid {
      display: grid;
      gap: 10px;
      grid-template-columns: 1.1fr 0.9fr;
    }
    .detail-card {
      border-radius: 12px;
      background: #edf3fc;
      box-shadow: inset 3px 3px 8px rgba(126, 149, 178, 0.16), inset -3px -3px 8px rgba(255, 255, 255, 0.82);
      padding: 12px;
    }
    .detail-card h3 {
      margin-bottom: 8px;
      font-size: 15px;
    }
    .detail-list {
      display: grid;
      gap: 8px;
      font-size: 12px;
      color: #2f3e5b;
    }
    .item-card {
      display: grid;
      grid-template-columns: 70px 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 10px;
      border-radius: 12px;
      background: linear-gradient(180deg, #ffffff, #edf2fb);
      border: 1px solid #d6deeb;
      margin-bottom: 8px;
    }
    .item-card img {
      width: 70px;
      height: 70px;
      object-fit: cover;
      border-radius: 10px;
      background: #fff;
    }
    .item-card p {
      font-size: 11px;
      color: #4e5f7c;
      margin-top: 2px;
    }
    .restock-modal {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
      background: rgba(10, 19, 35, 0.48);
    }
    .restock-modal.is-open {
      display: flex;
    }
    .restock-modal__dialog {
      width: min(420px, 100%);
      border-radius: 18px;
      border: 1px solid #c9d6ea;
      background: linear-gradient(180deg, #ffffff, #eef4fd);
      box-shadow: 0 20px 46px rgba(17, 36, 75, 0.24);
      padding: 18px;
    }
    .restock-modal__dialog h3 {
      margin: 0 0 8px;
      font-size: 20px;
      color: #0e1323;
    }
    .restock-modal__dialog p {
      margin: 0;
      color: #4e5f7c;
      font-size: 13px;
      line-height: 1.5;
    }
    .restock-modal__actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      margin-top: 18px;
      flex-wrap: wrap;
    }
    @media (max-width: 900px) {
      .detail-grid {
        grid-template-columns: 1fr;
      }
      .item-card {
        grid-template-columns: 1fr;
      }
      .item-card img {
        width: 100%;
        height: 180px;
      }
    }
  </style>
</head>
<body>
<main class="dashboard-scene">
  <section class="dashboard-card">
    <header class="top-strip">
      <div class="chip-row">
        <a href="/api/admin/dashboard" class="chip">Dashboard</a>
        <a href="/api/admin/products" class="chip">Products</a>
        <a href="/api/admin/category" class="chip">Categories</a>
        <a href="/api/admin/orders" class="chip chip-dark">Orders</a>
        <a href="/api/admin/adminusermanagement" class="chip">Users</a>
      </div>

      <form action="/api/admin/adminlogout" method="POST">
        <button type="submit" class="logout-pill">Logout</button>
      </form>
    </header>

    <section class="hero-panel">
      <div class="hero-copy">
        <h1>Order Detail</h1>
        <p>Review customer, shipping, item, and order status information for this order.</p>
      </div>
      <div class="hero-actions">
        <a href="/api/admin/orders" class="btn btn-light">Back to Orders</a>
        <a href="/api/admin/orders/<%= order._id %>/invoice" class="btn btn-dark">Download Invoice</a>
      </div>
    </section>

    <% if (message) { %>
      <p class="feedback success" data-flash-message><%= message %></p>
    <% } %>
    <% if (error) { %>
      <p class="feedback error" data-flash-message><%= error %></p>
    <% } %>

    <section class="detail-grid">
      <div class="detail-card">
        <h3>Items</h3>
        <% order.items.forEach((item, index) => { %>
          <article class="item-card">
            <img src="<%= item.productImage || 'https://placehold.co/140x140?text=Item' %>" alt="<%= item.productName %>" />
            <div>
              <strong><%= item.productName %></strong>
              <p>Qty: <%= item.quantity %></p>
              <% if (item.size || item.color) { %>
                <p>
                  <%= [
                    item.size ? "Size: " + item.size : "",
                    item.color ? "Color: " + item.color : ""
                  ].filter(Boolean).join(" | ") %>
                </p>
              <% } %>
              <p>Price: ₹<%= item.price %></p>
              <p>Subtotal: ₹<%= item.subtotal %></p>
              <p>Status: <%= item.status %></p>
              <% if (item.cancellationReason) { %>
                <p>Cancel reason: <%= item.cancellationReason %></p>
              <% } %>
              <% if (item.returnReason) { %>
                <p>Return reason: <%= item.returnReason %></p>
              <% } %>
              <% if (item.stockRestored) { %>
                <p>Stock restored after admin verification<%= item.restockVerifiedAt ? " on " + new Date(item.restockVerifiedAt).toLocaleDateString("en-IN") : "" %>.</p>
              <% } else if (["cancelled", "return_requested", "returned"].includes(item.status)) { %>
                <form
                  method="POST"
                  action="/api/admin/orders/<%= order._id %>/items/<%= index %>/restock"
                  style="margin-top:8px;"
                  data-restock-form
                  data-product-name="<%= item.productName %>"
                  data-confirm-message="<%= item.status === 'return_requested' ? 'Accept this return after checking the product condition, and restore it to stock?' : 'Confirm this product is in good condition and restore it to stock?' %>"
                  data-confirm-label="<%= item.status === 'return_requested' ? 'Accept Return & Restock' : 'Verify & Restock' %>"
                >
                  <button type="submit" class="btn btn-light"><%= item.status === "return_requested" ? "Accept Return & Restock" : "Verify & Restock" %></button>
                </form>
                <% if (item.status === "return_requested") { %>
                  <form
                    method="POST"
                    action="/api/admin/orders/<%= order._id %>/items/<%= index %>/reject-return"
                    style="margin-top:8px;"
                  >
                    <button type="submit" class="btn btn-light">Reject Return</button>
                  </form>
                <% } %>
              <% } %>
            </div>
            <span class="status-badge <%= item.status === 'delivered' ? 'active' : item.status === 'cancelled' ? 'soft-deleted' : 'inactive' %>">
              <%= item.status %>
            </span>
          </article>
        <% }) %>
      </div>

      <div class="detail-card">
        <h3>Order Summary</h3>
        <div class="detail-list">
          <div><strong>Order ID:</strong> <%= order.orderId %></div>
          <div><strong>Order Date:</strong> <%= order.createdAt ? new Date(order.createdAt).toLocaleString("en-IN") : "--" %></div>
          <div><strong>Status:</strong> <%= order.status %></div>
          <div><strong>Payment Method:</strong> <%= order.paymentMethod %></div>
          <div><strong>Payment Status:</strong> <%= order.paymentStatus %></div>
          <div><strong>Subtotal:</strong> ₹<%= order.subtotal %></div>
          <div><strong>Shipping:</strong> ₹<%= order.shippingCharge %></div>
          <div><strong>Tax:</strong> ₹<%= order.tax %></div>
          <div><strong>Discount:</strong> ₹<%= order.discount %></div>
          <div><strong>Grand Total:</strong> ₹<%= order.grandTotal %></div>
        </div>

        <h3 style="margin-top: 16px;">Customer Details</h3>
        <div class="detail-list">
          <div><strong>Name:</strong> <%= order.user?.name || "Unknown User" %></div>
          <div><strong>Email:</strong> <%= order.user?.email || "No email" %></div>
        </div>

        <h3 style="margin-top: 16px;">Shipping Address</h3>
        <div class="detail-list">
          <div><strong>Type:</strong> <%= order.address?.type || order.address?.addressType || "Address" %></div>
          <div><strong>Street:</strong> <%= order.address?.street || "--" %></div>
          <div><strong>City:</strong> <%= order.address?.city || "--" %></div>
          <div><strong>State:</strong> <%= order.address?.state || "--" %></div>
          <div><strong>Pincode:</strong> <%= order.address?.pincode || "--" %></div>
        </div>

        <%
          const detailStatusLabels = {
            pending: "Pending",
            shipped: "Shipped",
            out_for_delivery: "Out for delivery",
            delivered: "Delivered",
            cancelled: "Cancelled",
            return_requested: "Return requested",
            returned: "Returned",
            return_rejected: "Return rejected"
          };
          const detailTransitions = {
            pending:          ["shipped", "cancelled"],
            shipped:          ["out_for_delivery", "cancelled"],
            out_for_delivery: ["delivered", "cancelled"],
            delivered:        ["return_requested"],
            return_requested: ["returned", "return_rejected"],
            cancelled:        [],
            returned:         [],
            return_rejected:  []
          };
          const detailAllowed = detailTransitions[order.status] || [];
        %>
        <% if (detailAllowed.length) { %>
          <form method="POST" action="/api/admin/orders/<%= order._id %>/status" style="margin-top:16px;display:grid;gap:8px;">
            <input type="hidden" name="redirectTo" value="detail" />
            <label class="field">
              <span>Update Order Status</span>
              <select name="status" class="toolbar-select">
                <option value="<%= order.status %>" selected disabled><%= detailStatusLabels[order.status] || order.status %></option>
                <% detailAllowed.forEach(function(s) { %>
                  <option value="<%= s %>"><%= detailStatusLabels[s] || s %></option>
                <% }) %>
              </select>
            </label>
            <button type="submit" class="btn btn-dark">Save Status</button>
          </form>
        <% } else { %>
          <div style="margin-top:16px;">
            <span class="status-badge <%= order.status === 'delivered' ? 'active' : order.status === 'cancelled' ? 'soft-deleted' : 'inactive' %>">
              <%= detailStatusLabels[order.status] || order.status %> (final)
            </span>
          </div>
        <% } %>
      </div>
    </section>
  </section>
</main>
<div class="restock-modal" id="restockModal" aria-hidden="true">
  <div class="restock-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="restockModalTitle">
    <h3 id="restockModalTitle">Verify product condition</h3>
    <p id="restockModalText">
      Confirm this product is in good condition and restore it to stock.
    </p>
    <div class="restock-modal__actions">
      <button type="button" class="btn btn-light" id="cancelRestockModal">Cancel</button>
      <button type="button" class="btn btn-dark" id="confirmRestockModal">Verify & Restock</button>
    </div>
  </div>
</div>
<script>
  const restockModal = document.getElementById("restockModal");
  const restockModalText = document.getElementById("restockModalText");
  const cancelRestockModal = document.getElementById("cancelRestockModal");
  const confirmRestockModal = document.getElementById("confirmRestockModal");
  let pendingRestockForm = null;

  const closeRestockModal = () => {
    restockModal.classList.remove("is-open");
    restockModal.setAttribute("aria-hidden", "true");
    pendingRestockForm = null;
  };

  document.querySelectorAll("[data-restock-form]").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      pendingRestockForm = form;
      const productName = form.dataset.productName || "this product";
      restockModalText.textContent = `${productName}: ${form.dataset.confirmMessage || "Confirm this product is in good condition and restore it to stock."}`;
      confirmRestockModal.textContent = form.dataset.confirmLabel || "Verify & Restock";
      restockModal.classList.add("is-open");
      restockModal.setAttribute("aria-hidden", "false");
    });
  });

  cancelRestockModal.addEventListener("click", closeRestockModal);
  restockModal.addEventListener("click", (event) => {
    if (event.target === restockModal) {
      closeRestockModal();
    }
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && restockModal.classList.contains("is-open")) {
      closeRestockModal();
    }
  });
  confirmRestockModal.addEventListener("click", () => {
    if (pendingRestockForm) {
      pendingRestockForm.submit();
    }
  });
  setTimeout(() => {
    document.querySelectorAll("[data-flash-message]").forEach((msg) => msg.remove());
  }, 3000);
</script>
</body>
</html>
