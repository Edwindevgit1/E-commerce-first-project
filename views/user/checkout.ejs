<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Checkout</title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="stylesheet" href="/css/checkout.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <%- include("partials/storefront-navbar") %>

  <%
    const savedAddresses = Array.isArray(addresses) ? addresses : [];
    const selectedItems = Array.isArray(selectedProductIds)
      ? selectedProductIds
      : [selectedProductIds].filter(Boolean);
    const subtotal = Number(grandTotal) || 0;
    const discount = Number(couponDiscount || 0) || 0;
    const tax = 0;
    const shipping = subtotal >= 1000 ? 0 : 50;
    const finalTotal = subtotal + shipping + tax - discount;
    const availableWallet = Number(typeof walletBalance !== "undefined" ? walletBalance : 0) || 0;
    const canPayFullWithWallet = availableWallet >= finalTotal && finalTotal > 0;
    const redirectQuery = selectedItems
      .map(function(itemId) {
        return "selectedCartItemIds=" + encodeURIComponent(itemId);
      })
      .join("&");
    const checkoutRedirectUrl = "/api/user/checkout" + (redirectQuery ? "?" + redirectQuery : "");
  %>

  <main class="checkout-page">
    <header class="checkout-header">
      <h1>Checkout</h1>
      <p>Choose your delivery address, review your products, apply coupon, and pay with COD, wallet, or Razorpay.</p>
    </header>

    <section class="checkout-grid">
      <div class="checkout-main">
        <section class="checkout-panel">
          <div class="checkout-panel-head">
            <h2>Delivery Address</h2>
            <a href="/api/user/adress?redirect=<%= encodeURIComponent(checkoutRedirectUrl) %>" class="checkout-link">Add / Edit Address</a>
          </div>

          <% if (!savedAddresses.length) { %>
            <p class="empty-address">No saved address found. Please add an address before placing the order.</p>
          <% } else { %>
            <form id="placeOrderForm" action="/api/user/cart/place-order" method="POST">
              <% selectedItems.forEach(function(itemId) { %>
                <input type="hidden" name="selectedCartItemIds" value="<%= itemId %>" />
              <% }); %>
              <div class="address-list">
                <% savedAddresses.forEach(function(address, index) { %>
                  <label class="address-option">
                    <input
                      type="radio"
                      name="addressId"
                      value="<%= address._id %>"
                      <%= address.isDefault || index === 0 ? "checked" : "" %>
                      required
                    />
                    <span>
                      <strong>
                        <%= address.type || "Address" %>
                        <% if (address.isDefault) { %>
                          <span class="default-badge">Default</span>
                        <% } %>
                      </strong>
                      <%= address.street %>,
                      <%= address.city %>,
                      <%= address.state %> -
                      <%= address.pincode %>
                    </span>
                  </label>
                <% }); %>
              </div>
            </form>
          <% } %>
        </section>

        <section class="checkout-panel">
          <div class="checkout-panel-head">
            <h2>Products</h2>
          </div>

          <div class="checkout-item-list">
            <% checkoutItems.forEach(function(item) { %>
              <article class="checkout-item">
                <div class="checkout-item-image">
                  <img src="<%= item.productImage %>" alt="<%= item.productName %>" />
                </div>

                <div>
                  <h3><%= item.productName %></h3>
                  <p><%= item.category %></p>
                  <% if (item.size || item.color) { %>
                    <span>
                      <%= [
                        item.size ? "Size: " + item.size : "",
                        item.color ? "Color: " + item.color : ""
                      ].filter(Boolean).join(" | ") %>
                    </span>
                  <% } %>
                  <span>Price: ₹<%= item.price %></span>
                  <span>Quantity: <%= item.quantity %></span>
                </div>

                <div class="checkout-item-price">
                  ₹<%= item.subtotal %>
                </div>
              </article>
            <% }); %>
          </div>
        </section>

      </div>

      <aside class="checkout-summary">
        <h2>Price Details</h2>

        <% if (typeof message !== "undefined" && message) { %>
          <p class="feedback success"><%= message %></p>
        <% } %>
        <% if (typeof error !== "undefined" && error) { %>
          <p class="feedback error"><%= error %></p>
        <% } %>

        <div class="summary-row">
          <span>Subtotal</span>
          <strong>₹<%= subtotal %></strong>
        </div>

        <section class="summary-payment">
          <h3>Coupon</h3>
          <% if (coupon) { %>
            <form method="POST" action="/api/user/checkout/coupon/remove">
              <% selectedItems.forEach(function(itemId) { %>
                <input type="hidden" name="selectedCartItemIds" value="<%= itemId %>" />
              <% }); %>
              <div class="summary-row">
                <span><%= coupon.code %></span>
                <strong>- ₹<%= discount %></strong>
              </div>
              <button type="submit" class="checkout-submit">Remove Coupon</button>
            </form>
          <% } else { %>
            <form method="POST" action="/api/user/checkout/coupon/apply" class="coupon-form">
              <% selectedItems.forEach(function(itemId) { %>
                <input type="hidden" name="selectedCartItemIds" value="<%= itemId %>" />
              <% }); %>
              <input type="text" name="couponCode" class="coupon-input" placeholder="Enter coupon code" required />
              <button type="submit" class="checkout-submit">Apply Coupon</button>
            </form>
          <% } %>
        </section>

        <div class="summary-row">
          <span>Discount</span>
          <strong>- ₹<%= discount %></strong>
        </div>

        <div class="summary-row">
          <span>Tax</span>
          <strong>₹<%= tax %></strong>
        </div>

        <div class="summary-row">
          <span>Shipping</span>
          <strong><%= shipping === 0 ? "Free" : "₹" + shipping %></strong>
        </div>

        <div class="summary-row summary-total">
          <span>Final Price</span>
          <strong>₹<%= finalTotal %></strong>
        </div>

        <section class="summary-payment">
          <h3>Payment Method</h3>

          <label class="summary-payment-option">
            <input
              type="radio"
              name="paymentMethod"
              value="COD"
              form="placeOrderForm"
              checked
            />
            <span>
              <strong>Cash on Delivery</strong>
              <small>Pay when your order is delivered.</small>
            </span>
          </label>

          <label class="summary-payment-option">
            <input
              type="radio"
              name="paymentMethod"
              value="RAZORPAY"
              form="placeOrderForm"
            />
            <span>
              <strong>Razorpay</strong>
              <small>Pay online using card, UPI, or net banking.</small>
            </span>
          </label>

          <label class="summary-payment-option <%= canPayFullWithWallet ? '' : 'is-disabled' %>">
            <input
              type="radio"
              name="paymentMethod"
              value="WALLET"
              form="placeOrderForm"
              <%= canPayFullWithWallet ? '' : 'disabled' %>
            />
            <span>
              <strong>Wallet</strong>
              <small>
                Balance: ₹<%= availableWallet %>
                <% if (!canPayFullWithWallet) { %>
                  | Need ₹<%= finalTotal %>
                <% } %>
              </small>
            </span>
          </label>

          <input
            type="hidden"
            name="walletAmount"
            form="placeOrderForm"
            value="<%= finalTotal %>"
          />
        </section>

        <button
          type="submit"
          form="placeOrderForm"
          id="placeOrderButton"
          class="checkout-submit"
          <%= !savedAddresses.length ? "disabled" : "" %>
        >
          Place Order
        </button>
      </aside>
    </section>
  </main>

  <%- include("partials/site-footer") %>
  <% if (razorpayKeyId) { %>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <% } %>
  <script>
    (() => {
      const form = document.getElementById("placeOrderForm");
      const button = document.getElementById("placeOrderButton");
      if (!form || !button) return;

      form.addEventListener("submit", async (event) => {
        const paymentInput = document.querySelector('input[name="paymentMethod"]:checked');
        const paymentMethod = paymentInput ? paymentInput.value : "COD";

        if (paymentMethod !== "RAZORPAY") return;

        event.preventDefault();

        try {
          button.disabled = true;
          button.textContent = "Starting payment...";

          const formData = new FormData(form);
          const response = await fetch("/api/user/checkout/razorpay/create-order", {
            method: "POST",
            body: new URLSearchParams(formData)
          });
          const payload = await response.json();

          if (!response.ok || !payload.success) {
            throw new Error(payload.message || "Unable to create Razorpay order");
          }

          const razorpay = new Razorpay({
            key: payload.key,
            amount: payload.amount,
            currency: payload.currency,
            order_id: payload.orderId,
            name: "Nike Store",
            description: "Checkout Payment",
            handler: async function (paymentResponse) {
              const verifyResponse = await fetch("/api/user/checkout/razorpay/verify", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(paymentResponse)
              });
              const verifyPayload = await verifyResponse.json();

              if (verifyPayload.success) {
                window.location.href = verifyPayload.redirectUrl;
                return;
              }

              window.location.href = verifyPayload.redirectUrl || "/api/user/payment-failure";
            },
            modal: {
              ondismiss: function () {
                window.location.href = "/api/user/payment-failure?message="
                  + encodeURIComponent("Payment cancelled. Please try again.")
                  + "&retryUrl="
                  + encodeURIComponent("<%= checkoutRedirectUrl %>");
              }
            },
            theme: {
              color: "#0a2052"
            }
          });

          razorpay.open();
        } catch (error) {
          window.location.href = "/api/user/payment-failure?message="
            + encodeURIComponent(error.message || "Unable to start payment")
            + "&retryUrl="
            + encodeURIComponent("<%= checkoutRedirectUrl %>");
        } finally {
          button.disabled = false;
          button.textContent = "Place Order";
        }
      });
    })();
  </script>
</body>
</html>
