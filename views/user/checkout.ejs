<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Checkout</title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="stylesheet" href="/css/checkout.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <%- include("partials/storefront-navbar") %>

  <%
    const savedAddresses = Array.isArray(addresses) ? addresses : [];
    const selectedItems = Array.isArray(selectedProductIds)
      ? selectedProductIds
      : [selectedProductIds].filter(Boolean);
    const subtotal = Number(grandTotal) || 0;
    const discount = 0;
    const tax = 0;
    const shipping = subtotal >= 1000 ? 0 : 50;
    const finalTotal = subtotal + shipping + tax - discount;
    const availableWallet = Number(walletBalance) || 0;
    const canPayFullWithWallet = availableWallet >= finalTotal && finalTotal > 0;
    const redirectQuery = selectedItems
      .map(function(itemId) {
        return "selectedCartItemIds=" + encodeURIComponent(itemId);
      })
      .join("&");
    const checkoutRedirectUrl = "/api/user/checkout" + (redirectQuery ? "?" + redirectQuery : "");
  %>

  <main class="checkout-page">
    <header class="checkout-header">
      <h1>Checkout</h1>
      <p>Choose your delivery address, review your products, and place your Cash on Delivery order.</p>
    </header>

    <section class="checkout-grid">
      <div class="checkout-main">
        <section class="checkout-panel">
          <div class="checkout-panel-head">
            <h2>Delivery Address</h2>
            <a href="/api/user/adress?redirect=<%= encodeURIComponent(checkoutRedirectUrl) %>" class="checkout-link">Add / Edit Address</a>
          </div>

          <% if (!savedAddresses.length) { %>
            <p class="empty-address">No saved address found. Please add an address before placing the order.</p>
          <% } else { %>
            <form id="placeOrderForm" action="/api/user/cart/place-order" method="POST">
              <% selectedItems.forEach(function(itemId) { %>
                <input type="hidden" name="selectedCartItemIds" value="<%= itemId %>" />
              <% }); %>
              <div class="address-list">
                <% savedAddresses.forEach(function(address, index) { %>
                  <label class="address-option">
                    <input
                      type="radio"
                      name="addressId"
                      value="<%= address._id %>"
                      <%= address.isDefault || index === 0 ? "checked" : "" %>
                      required
                    />
                    <span>
                      <strong>
                        <%= address.type || "Address" %>
                        <% if (address.isDefault) { %>
                          <span class="default-badge">Default</span>
                        <% } %>
                      </strong>
                      <%= address.street %>,
                      <%= address.city %>,
                      <%= address.state %> -
                      <%= address.pincode %>
                    </span>
                  </label>
                <% }); %>
              </div>
            </form>
          <% } %>
        </section>

        <section class="checkout-panel">
          <div class="checkout-panel-head">
            <h2>Products</h2>
          </div>

          <div class="checkout-item-list">
            <% checkoutItems.forEach(function(item) { %>
              <article class="checkout-item">
                <div class="checkout-item-image">
                  <img src="<%= item.productImage %>" alt="<%= item.productName %>" />
                </div>

                <div>
                  <h3><%= item.productName %></h3>
                  <p><%= item.category %></p>
                  <% if (item.size || item.color) { %>
                    <span>
                      <%= [
                        item.size ? "Size: " + item.size : "",
                        item.color ? "Color: " + item.color : ""
                      ].filter(Boolean).join(" | ") %>
                    </span>
                  <% } %>
                  <span>Price: ₹<%= item.price %></span>
                  <span>Quantity: <%= item.quantity %></span>
                </div>

                <div class="checkout-item-price">
                  ₹<%= item.subtotal %>
                </div>
              </article>
            <% }); %>
          </div>
        </section>

      </div>

      <aside class="checkout-summary">
        <h2>Price Details</h2>

        <div class="summary-row">
          <span>Subtotal</span>
          <strong>₹<%= subtotal %></strong>
        </div>

        <div class="summary-row">
          <span>Discount</span>
          <strong>- ₹<%= discount %></strong>
        </div>

        <div class="summary-row">
          <span>Tax</span>
          <strong>₹<%= tax %></strong>
        </div>

        <div class="summary-row">
          <span>Shipping</span>
          <strong><%= shipping === 0 ? "Free" : "₹" + shipping %></strong>
        </div>

        <div class="summary-row summary-total">
          <span>Final Price</span>
          <strong>₹<%= finalTotal %></strong>
        </div>

        <section class="summary-payment">
          <h3>Payment Method</h3>

          <label class="summary-payment-option">
            <input
              type="radio"
              name="paymentMethod"
              value="COD"
              form="placeOrderForm"
              checked
            />
            <span>
              <strong>Cash on Delivery</strong>
              <small>Pay when your order is delivered.</small>
            </span>
          </label>

          <label class="summary-payment-option <%= canPayFullWithWallet ? '' : 'is-disabled' %>">
            <input
              type="radio"
              name="paymentMethod"
              value="WALLET"
              form="placeOrderForm"
              <%= canPayFullWithWallet ? '' : 'disabled' %>
            />
            <span>
              <strong>Wallet</strong>
              <small>
                Balance: ₹<%= availableWallet %>
                <% if (!canPayFullWithWallet) { %>
                  | Need ₹<%= finalTotal %>
                <% } %>
              </small>
            </span>
          </label>

          <input
            type="hidden"
            name="walletAmount"
            form="placeOrderForm"
            value="<%= finalTotal %>"
          />
        </section>

        <button
          type="submit"
          form="placeOrderForm"
          class="checkout-submit"
          <%= !savedAddresses.length ? "disabled" : "" %>
        >
          Place Order
        </button>
      </aside>
    </section>
  </main>

  <%- include("partials/site-footer") %>
</body>
</html>
