<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password OTP</title>
    <link rel="stylesheet" href="/css/verify.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="neo-scene">
      <section class="neo-card">
        <header class="top-strip">
          <div class="chip-row">
            <a href="/api/auth/login" class="chip">Login</a>
            <a href="/api/auth/forgotpassword" class="chip">Forgot Password</a>
            <span class="chip chip-dark">Verify OTP</span>
          </div>

          <button type="button" class="profile-chip" aria-label="Profile">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 12a4.5 4.5 0 1 0-4.5-4.5A4.5 4.5 0 0 0 12 12Zm0 2.25c-4.15 0-7.5 2.03-7.5 4.5V20h15v-1.25c0-2.47-3.35-4.5-7.5-4.5Z"
              />
            </svg>
          </button>
        </header>

        <div class="title-block">
          <h1>Verify Reset OTP</h1>
          <p>Enter the 6-digit OTP sent to your email</p>
        </div>

        <div class="message-slot">
          <% if (typeof error !== "undefined" && error) { %>
            <div id="errorBox" class="error-message"><%= error %></div>
          <% } else { %>
            <div class="error-placeholder"></div>
          <% } %>
        </div>

        <form action="/api/auth/verify" method="POST" class="otp-form" id="otpForm">
          <div class="otp-row">
            <input class="otp-input" name="otp1" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" />
            <input class="otp-input" name="otp2" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" />
            <input class="otp-input" name="otp3" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" />
            <input class="otp-input" name="otp4" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" />
            <input class="otp-input" name="otp5" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" />
            <input class="otp-input" name="otp6" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" />
          </div>

          <input type="hidden" name="otp" id="otpValue" />

          <button type="submit" class="primary-btn">Verify OTP</button>

          <div class="links">
            <button type="button" id="resendBtn" class="resend-btn" disabled>
              Resend OTP (<span id="timerText">00:30</span>)
            </button>
            <a href="/api/auth/forgot-cancel-reset">Back to login</a>
          </div>
        </form>
      </section>
    </main>

    <script src="/script/verify-timer.js"></script>
  </body>
</html>
