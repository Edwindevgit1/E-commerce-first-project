<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile</title>
    <link rel="stylesheet" href="/css/userprofile.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="neo-scene">
      <section class="neo-card">
        <header class="top-strip">
          <div class="chip-row">
            <a href="/api/auth/home" class="chip">Home</a>
            <a href="/api/user/profile" class="chip chip-dark">Account</a>
            <a href="/api/user/wallet" class="chip">Wallet</a>
            <a href="/api/user/orders" class="chip">My orders</a>
            <a href="/api/user/adress" class="chip">Address management</a>
            <% if ((user.authProvider || user.provider) === "local") { %>
              <a href="/api/user/change-password" class="chip">Change password</a>
            <% } %>
          </div>

          <form action="/api/user/logout" method="POST">
            <button class="logout-pill" type="submit">Logout</button>
          </form>
        </header>

        <section class="profile-main">
          <div class="hero">
            <div class="avatar-wrap">
              <img
                src="<%= user.profileImage ? user.profileImage : '/images/avatar.png' %>"
                class="big-avatar"
                id="avatarPreview"
                alt="avatar"
              />
            </div>

            <div class="hero-text">
              <h1>My Profile</h1>
              <p>Manage your account details and profile picture</p>
            </div>

            <div class="photo-actions">
              <% if (user.profileImage && user.profileImage !== '/images/avatar.png') { %>
                <form
                  action="/api/user/delete-avatar"
                  method="POST"
                  onsubmit="return confirm('Remove profile picture?')"
                >
                  <button type="submit" class="delete-avatar-btn">Remove Photo</button>
                </form>
              <% } %>

              <div class="button-group top-actions">
                <button type="button" id="editBtn" class="btn btn-light">Edit</button>
                <button type="submit" form="profileForm" id="saveBtn" class="btn btn-dark" style="display:none;">Save</button>
                <button type="button" id="cancelBtn" class="btn btn-light" style="display:none;">Cancel</button>
              </div>
            </div>
          </div>

          <div class="message-slot">
            <% if (typeof error !== "undefined" && error) { %>
              <div id="errorBox" class="error-message"><%= error %></div>
            <% } else { %>
              <div class="error-placeholder"></div>
            <% } %>
          </div>

          <form
            id="profileForm"
            action="/api/user/update-profile"
            method="POST"
            enctype="multipart/form-data"
            class="profile-form"
            novalidate
          >
            <div class="field-wrap">
              <label>Profile Image</label>
              <div class="field field-light">
                <input type="file" name="profileImage" id="imageInput" accept="image/*" disabled/>
              </div>
            </div>

            <div class="field-wrap">
              <label>Full Name</label>
              <div class="field field-dark">
                <input
                  type="text"
                  name="name"
                  value="<%= user.name %>"
                  id="nameInput"
                  disabled
                />
              </div>
            </div>

            <div class="field-wrap">
              <label>Email</label>
              <div class="field field-dark">
                <input
                  type="email"
                  name="email"
                  value="<%= user.email %>"
                  id="emailInput"
                  data-editable="<%= (user.authProvider || user.provider) === 'local' ? 'true' : 'false' %>"
                  disabled
                  <%= (user.authProvider || user.provider) === "google" ? 'readonly' : '' %>
                />
              </div>
            </div>

            <% if (referralSettings?.referralDisplayEnabled !== false) { %>
              <section class="referral-summary">
                <div class="referral-copy">
                  <span class="referral-label">Your Referral Code</span>
                  <strong id="referralCodeValue"><%= user.referralCode || "USER" %></strong>
                </div>
                <% if (user.referralSuspended) { %>
                  <p>Your referral account is suspended by admin.</p>
                <% } else { %>
                  <p>
                    Share your code or copy your referral link. Rewards unlock after
                    referred user places first successful order meeting admin minimum purchase.
                  </p>
                  <div class="button-group top-actions">
                    <button type="button" id="copyReferralCodeBtn" class="btn btn-light">Copy Code</button>
                    <button type="button" id="copyReferralLinkBtn" class="btn btn-dark">Copy Referral Link</button>
                  </div>
                  <input type="hidden" id="referralLinkValue" value="<%= referralLink %>" />
                <% } %>
              </section>
            <% } %>
          </form>
        </section>
      </section>
    </main>

    <script>
      window.addEventListener("pageshow", function (event) {
      if (event.persisted) {
      window.location.reload();
      }
      });
      const input = document.getElementById("imageInput");
      const preview = document.getElementById("avatarPreview");
      const imageInput = document.getElementById("imageInput");
      const form=document.getElementById('profileForm')
      const originalAvatar=preview.src;

      input?.addEventListener("change", function () {
        const file = this.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (e) {
          preview.src = e.target.result;
        };
        reader.readAsDataURL(file);
      });

      const editBtn = document.getElementById("editBtn");
      const saveBtn = document.getElementById("saveBtn");
      const cancelBtn = document.getElementById("cancelBtn");
      const nameInput = document.getElementById("nameInput");
      const emailInput = document.getElementById("emailInput");
      const copyReferralCodeBtn = document.getElementById("copyReferralCodeBtn");
      const copyReferralLinkBtn = document.getElementById("copyReferralLinkBtn");
      const referralCodeValue = document.getElementById("referralCodeValue");
      const referralLinkValue = document.getElementById("referralLinkValue");

        editBtn?.addEventListener("click", function () {
        nameInput.disabled = false;
        if (emailInput && emailInput.dataset.editable === "true") {
          emailInput.disabled = false;
        }
        imageInput.disabled = false;

        editBtn.style.display = "none";
        saveBtn.style.display = "inline-flex";
        cancelBtn.style.display = "inline-flex";
      });

      cancelBtn?.addEventListener("click", function (e) {
        e.preventDefault()
        console.log(e.target)
        console.log(e.type)
        console.log(e.clientX)

        form.reset()
        preview.src=originalAvatar

        nameInput.disabled = true;
        emailInput.disabled = true;
        imageInput.disabled=true;

        editBtn.style.display = "inline-flex";
        saveBtn.style.display = "none";
        cancelBtn.style.display = "none";
      });

      setTimeout(() => {
        const errorBox = document.getElementById("errorBox");
        if (errorBox) errorBox.style.display = "none";
      }, 3000);

      const copyText = async (value, button, successText) => {
        if (!value || !button) return;
        const originalText = button.textContent;
        try {
          await navigator.clipboard.writeText(value);
          button.textContent = successText;
          setTimeout(() => {
            button.textContent = originalText;
          }, 1500);
        } catch (error) {
          button.textContent = "Copy failed";
          setTimeout(() => {
            button.textContent = originalText;
          }, 1500);
        }
      };

      copyReferralCodeBtn?.addEventListener("click", () => {
        copyText(referralCodeValue?.textContent?.trim(), copyReferralCodeBtn, "Code Copied");
      });

      copyReferralLinkBtn?.addEventListener("click", () => {
        copyText(referralLinkValue?.value?.trim(), copyReferralLinkBtn, "Link Copied");
      });
    </script>
    <%- include("partials/site-footer") %>
  </body>
</html>
