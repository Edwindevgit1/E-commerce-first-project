<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Forgot Password</title>
  <link rel="stylesheet" href="/css/forgot-password.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<header class="navbar">
  <div class="nav-container">
    <div class="logo">NIKE</div>

    <nav class="nav-links">
      <a href="#">Men</a>
      <a href="#">Women</a>
      <a href="#">Shoe</a>
      <a href="#">Hot deals</a>
    </nav>

    <div class="nav-icons">
      <input type="text" placeholder="Search">
    </div>
  </div>
</header>

<div class="main-container">


  <div class="left-panel">
    <div class="left-bg">

      <div class="forgot-box">

        <h1>Forgot password ?</h1>
        <p class="subtitle">
          Enter your registered email, we will send you a reset link
        </p>

        <% if (typeof error !== "undefined" && error) { %>
          <div class="error-message">
            <%= error %>
          </div>
        <% } %>

        <form action="/api/auth/forgotpassword" method="POST">

          <label for="email">Email</label>
          <input type="email" id="email" name="email">

          <button type="submit" class="reset-btn">
            Send reset otp
          </button>

        </form>

        <p class="back-login">
          Back to <a href="/api/auth/login">login</a>
        </p>

      </div>
    </div>
  </div>


  <div class="right-panel">
    <img src="/images/authbackground.png" alt="Forgot Background">
  </div>

</div>

</body>
</html>