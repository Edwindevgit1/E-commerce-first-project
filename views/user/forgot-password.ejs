<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password</title>
    <link rel="stylesheet" href="/css/forgot-password.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="neo-scene">
      <section class="neo-card">
        <header class="top-strip">
          <div class="chip-row">
            <a href="/api/auth/register" class="chip">Sign up</a>
            <a href="/api/auth/login" class="chip">Login</a>
            <span class="chip chip-dark">Forgot Password</span>
          </div>
          <button type="button" class="profile-chip" aria-label="Profile menu">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 12a4.5 4.5 0 1 0-4.5-4.5A4.5 4.5 0 0 0 12 12Zm0 2.25c-4.15 0-7.5 2.03-7.5 4.5V20h15v-1.25c0-2.47-3.35-4.5-7.5-4.5Z"
              />
            </svg>
          </button>
        </header>

        <div class="title-block">
          <h1>Forgot Password?</h1>
          <p>Enter your registered email, we will send you a reset OTP</p>
        </div>

        <div class="message-slot">
          <% if (typeof error !== "undefined" && error) { %>
            <div id="errorBox" class="error-message"><%= error %></div>
          <% } else { %>
            <div class="error-placeholder"></div>
          <% } %>
        </div>

        <form action="/api/auth/forgotpassword" method="POST" class="forgot-form">
          <label for="email" class="sr-only">Email</label>
          <div class="field field-dark">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path
                fill="currentColor"
                d="M4 6.75A1.75 1.75 0 0 1 5.75 5h12.5A1.75 1.75 0 0 1 20 6.75v10.5A1.75 1.75 0 0 1 18.25 19H5.75A1.75 1.75 0 0 1 4 17.25V6.75Zm1.73-.25 6.27 5.02 6.27-5.02H5.73Zm12.77 1.9-5.73 4.59a1.2 1.2 0 0 1-1.54 0L5.5 8.4v8.85c0 .14.11.25.25.25h12.5a.25.25 0 0 0 .25-.25V8.4Z"
              />
            </svg>
            <input id="email" name="email" type="email" placeholder="Email address" />
          </div>

          <button type="submit" class="primary-btn">Send reset OTP</button>

          <p class="footer-text">
            Back to <a href="/api/auth/login">Login</a>
          </p>
        </form>
      </section>
    </main>

    <script>
      window.addEventListener("pageshow", function (event) {
     if (event.persisted) {
     window.location.reload();
     }
     });
      setTimeout(() => {
        const errorBox = document.getElementById("errorBox");
        if (errorBox) errorBox.style.display = "none";
      }, 3000);
    </script>
  </body>
</html>
