<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products</title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="stylesheet" href="/css/user-products.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <%- include("partials/storefront-navbar") %>

  <main class="shop-shell">
    <div id="listingContent">
      <%- include("partials/product-listing-content") %>
    </div>
  </main>

  <script>
    window.addEventListener("load", () => {
      history.replaceState({ productListingPage: true }, "", location.href);
      history.pushState({ productListingGuard: true }, "", location.href);
    });

    const listingContent = document.getElementById("listingContent");

    async function updateListing(url, push = true) {
      const fetchUrl = new URL(url, window.location.origin);
      fetchUrl.searchParams.set("partial", "1");

      const response = await fetch(fetchUrl.toString(), {
        headers: { "X-Requested-With": "XMLHttpRequest" }
      });

      if (!response.ok) return;

      const html = await response.text();
      listingContent.innerHTML = html;

      if (push) {
        const cleanUrl = new URL(url, window.location.origin);
        window.history.replaceState(
          { productListingGuard: true },
          "",
          cleanUrl.pathname + cleanUrl.search
        );
        syncNavbarState(cleanUrl);
      }

      bindListingInteractions();
      bindNavbarCategoryLinks();
      document.getElementById("listingShell")?.scrollIntoView({ block: "start" });
    }

    function syncNavbarState(urlLike = window.location.href) {
      const currentUrl = new URL(urlLike, window.location.origin);
      const params = currentUrl.searchParams;
      const searchForm = document.querySelector(".store-search");
      const searchInput = searchForm?.querySelector('input[name="search"]');
      const clearBtn = searchForm?.querySelector("[data-store-search-clear]");

      if (searchInput) {
        searchInput.value = params.get("search") || "";
      }

      const syncHiddenField = (name, value) => {
        if (!searchForm) return;
        let field = searchForm.querySelector(`input[name="${name}"]`);
        if (!value) {
          field?.remove();
          return;
        }
        if (!field) {
          field = document.createElement("input");
          field.type = "hidden";
          field.name = name;
          searchForm.appendChild(field);
        }
        field.value = value;
      };

      syncHiddenField("category", params.get("category") || "");
      syncHiddenField("sort", params.get("sort") || "");
      syncHiddenField("priceRange", params.get("priceRange") || "");
      syncHiddenField("size", params.get("size") || "");
      syncHiddenField("color", params.get("color") || "");

      clearBtn?.classList.toggle("visible", Boolean((params.get("search") || "").trim()));

      document.querySelectorAll(".store-category-track a").forEach((link) => {
        const linkUrl = new URL(link.href, window.location.origin);
        const categoryValue = linkUrl.searchParams.get("category") || "";
        const activeCategory = params.get("category") || "";

        link.classList.toggle("active", categoryValue === activeCategory);

        const rebuilt = new URL("/api/user/products", window.location.origin);
        if (categoryValue) rebuilt.searchParams.set("category", categoryValue);
        ["search", "sort", "priceRange", "size", "color"].forEach((key) => {
          const value = params.get(key);
          if (value) {
            rebuilt.searchParams.set(key, value);
          }
        });
        link.href = rebuilt.pathname + rebuilt.search;
      });
    }

    function bindNavbarCategoryLinks() {
      document.querySelectorAll(".store-category-track a").forEach((link) => {
        link.addEventListener("click", (event) => {
          const targetUrl = new URL(link.href, window.location.origin);
          if (!targetUrl.pathname.startsWith("/api/user/products")) return;
          event.preventDefault();
          updateListing(targetUrl.toString());
        });
      });
    }

    function bindListingInteractions() {
      const filterForm = document.getElementById("listingFilterForm");
      const sortForm = document.getElementById("listingSortForm");
      const sortDropdown = sortForm?.querySelector("[data-sort-dropdown]");
      const sortToggle = sortForm?.querySelector("[data-sort-toggle]");
      const sortMenu = sortForm?.querySelector("[data-sort-menu]");
      const sortInput = sortForm?.querySelector('input[name="sort"]');
      const sortLabel = sortForm?.querySelector("[data-sort-label]");

      filterForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const params = new URLSearchParams(new FormData(filterForm));
        updateListing(`/api/user/products?${params.toString()}`);
      });

      filterForm?.querySelectorAll("[data-filter-group]")?.forEach((group) => {
        const toggle = group.querySelector("[data-filter-toggle]");
        toggle?.addEventListener("click", () => {
          const isOpen = group.classList.toggle("open");
          toggle.setAttribute("aria-expanded", String(isOpen));
        });
      });

      sortToggle?.addEventListener("click", () => {
        const isOpen = sortDropdown.classList.toggle("open");
        sortToggle.setAttribute("aria-expanded", String(isOpen));
      });

      sortMenu?.querySelectorAll("[data-sort-value]")?.forEach((option) => {
        option.addEventListener("click", () => {
          if (!sortInput || !sortLabel) return;
          sortInput.value = option.dataset.sortValue || "";
          sortLabel.textContent = option.textContent.trim();
          sortDropdown?.classList.remove("open");
          sortToggle?.setAttribute("aria-expanded", "false");

          const params = new URLSearchParams(new FormData(sortForm));
          updateListing(`/api/user/products?${params.toString()}`);
        });
      });

      if (window.listingSortOutsideClickHandler) {
        document.removeEventListener("click", window.listingSortOutsideClickHandler);
      }

      window.listingSortOutsideClickHandler = (event) => {
        if (!sortDropdown) return;
        if (!sortDropdown.contains(event.target)) {
          sortDropdown.classList.remove("open");
          sortToggle?.setAttribute("aria-expanded", "false");
        }
      };

      document.addEventListener("click", window.listingSortOutsideClickHandler);

      listingContent.querySelectorAll("[data-listing-link]").forEach((link) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          updateListing(link.href);
        });
      });
    }

    window.addEventListener("popstate", (event) => {
      if (event.state?.productListingPage || event.state?.productListingGuard) {
        window.location.replace("/api/auth/home");
        return;
      }
    });

    bindListingInteractions();
    bindNavbarCategoryLinks();
    syncNavbarState(window.location.href);
  </script>
<%- include("partials/site-footer") %>
</body>
</html>
