<style>
  .site-footer {
    max-width: 1180px;
    margin: 18px auto 0;
    padding: 24px 22px;
    border-top: 1px solid rgba(14, 19, 35, 0.12);
    color: #5e6472;
    font-family: "Sora", sans-serif;
  }

  .site-footer__summary {
    max-width: 620px;
    margin-bottom: 18px;
  }

  .site-footer__title {
    margin: 0 0 8px;
    color: #151927;
    font-size: 15px;
    font-weight: 800;
  }

  .site-footer__text {
    max-width: 560px;
  }

  .site-footer__policy-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-bottom: 18px;
  }

  .site-footer__policy-title {
    margin: 0 0 6px;
    color: #232838;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .site-footer__legal {
    padding-top: 14px;
    border-top: 1px solid rgba(14, 19, 35, 0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .site-footer__brand {
    color: #151927;
    font-size: 13px;
    font-weight: 700;
  }

  .site-footer__links {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .site-footer p,
  .site-footer a {
    margin: 0;
    color: #6f7480;
    font-size: 12px;
    line-height: 1.7;
    text-decoration: none;
  }

  .site-footer a:hover {
    color: #111827;
  }

  @media (max-width: 700px) {
    .site-footer {
      padding: 18px 12px;
    }

    .site-footer__policy-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .site-footer__summary {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .site-footer__legal,
    .site-footer__links {
      justify-content: center;
      text-align: center;
    }
  }
</style>

<footer class="site-footer">
  <div class="site-footer__summary">
    <h3 class="site-footer__title">Move with confidence.</h3>
    <p class="site-footer__text">
      Nike Store brings together performance footwear, everyday essentials, and a secure shopping experience for every customer.
    </p>
  </div>

  <div class="site-footer__policy-grid">
    <div>
      <h4 class="site-footer__policy-title">Company Policy</h4>
      <p>Products are reviewed for quality and availability before listing.</p>
    </div>
    <div>
      <h4 class="site-footer__policy-title">Terms &amp; Conditions</h4>
      <p>Orders, offers, and account activity follow store usage and checkout rules.</p>
    </div>
    <div>
      <h4 class="site-footer__policy-title">Customer Support</h4>
      <p>For claims, privacy, or order questions, contact support through your account.</p>
    </div>
  </div>

  <div class="site-footer__legal">
    <p class="site-footer__brand">&copy; <%= new Date().getFullYear() %> Nike, Inc. All rights reserved</p>
    <nav class="site-footer__links" aria-label="Footer legal navigation">
      <a href="#">Terms of Use</a>
      <a href="#">Nike Privacy Policy</a>
      <a href="#">Store Claim Policy</a>
    </nav>
  </div>
</footer>
