<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.productName %></title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="stylesheet" href="/css/user-products.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <%- include("partials/storefront-navbar") %>

  <main class="details-shell">
    <nav class="breadcrumb">
      <a href="/api/user/products" class="breadcrumb-back" aria-label="Back to products">←</a>
      <a href="/api/user/products">Home</a> /
      <span><%= categoryName %></span> /
      <strong><%= product.productName %></strong>
    </nav>

    <% if (pageMessage) { %>
      <p class="detail-page-message"><%= pageMessage %></p>
    <% } %>

    <section class="details-grid">
      <section class="detail-gallery">
        <div class="main-preview-frame">
          <img
            id="mainPreview"
            src="<%= initialGalleryImages[initialMainImageIndex] || initialGalleryImages[0] || productImages[product.mainImageIndex || 0] || productImages[0] || fallbackProductImage %>"
            class="main-preview"
            alt="<%= product.productName %>"
          />
        </div>

        <div class="thumb-row" id="thumbRow">
          <% initialGalleryImages.forEach(function(image) { %>
            <button type="button" class="thumb-button" data-thumb-src="<%= image %>">
              <img
                src="<%= image %>"
                class="thumb-item"
                alt="thumb"
              />
            </button>
          <% }); %>
        </div>

        <div class="detail-tabs">
          <button type="button" class="detail-tab active" data-detail-tab="details">Details</button>
          <button type="button" class="detail-tab" data-detail-tab="reviews">Reviews</button>
          <button type="button" class="detail-tab" data-detail-tab="shipping">Shipping</button>
        </div>

        <div class="detail-copy-panels">
          <div class="detail-copy-panel active" data-detail-panel="details">
            <% if (product.description) { %>
              <p><%= product.description %></p>
            <% } %>

            <% if (productHighlights.length) { %>
              <ul class="highlights detail-highlights">
                <% productHighlights.forEach(function(item) { %>
                  <li><%= item %></li>
                <% }); %>
              </ul>
            <% } %>

            <% if (!product.description && !productHighlights.length) { %>
              <p>Product details will be available soon.</p>
            <% } %>
          </div>
          <div class="detail-copy-panel" data-detail-panel="reviews">
            <% if (!productReviews.length) { %>
              <p>No reviews yet.</p>
            <% } %>

            <% productReviews.forEach(function(review) { %>
              <article class="review-card">
                <strong><%= review.userName %></strong>
                <p><%= review.comment %></p>
              </article>
            <% }); %>
          </div>
          <div class="detail-copy-panel" data-detail-panel="shipping">
            <p><%= product.shippingInfo || "Standard delivery timelines and shipping updates will be shown here for this product." %></p>
          </div>
        </div>
      </section>

      <section class="detail-info-card">
        <div class="detail-info-header">
          <h1><%= product.productName %></h1>
          <% if (!isInCart) { %>
            <form action="/api/user/wishlist/add/<%= product._id %>" method="POST" class="wishlist-form">
              <button
                type="submit"
                class="wishlist-btn"
                aria-label="Add to wishlist"
                title="Add to wishlist"
              >
                ♡
              </button>
            </form>
          <% } %>
        </div>

        <div class="price-box">
          <strong id="selectedVariantPrice">₹<%= defaultVariant ? defaultVariant.effectivePrice : product.displayPrice %></strong>
          <% if ((defaultVariant ? defaultVariant.hasDiscount : product.hasDiscount)) { %>
            <span class="old-price" id="selectedVariantOriginalPrice">₹<%= defaultVariant ? defaultVariant.originalPrice : product.originalPrice %></span>
          <% } else { %>
            <span class="old-price" id="selectedVariantOriginalPrice" hidden></span>
          <% } %>
        </div>

        <% if (product.discountSource === "category") { %>
          <p class="coupon-box">
            Category Offer: <strong><%= product.categoryOfferPercentage %>% off</strong>
          </p>
        <% } %>

        <% if (product.couponCode) { %>
          <p class="coupon-box">
            Coupon: <strong><%= product.couponCode %></strong> - <%= product.couponDescription %>
          </p>
        <% } %>

        <div class="description-box">
          <h3>description</h3>
          <p><%= product.description || "No description available for this product yet." %></p>
        </div>

        <div class="stock-box">
          <% if (availabilityState === "product_inactive") { %>
            <span class="danger-text">Temporarily unavailable</span>
          <% } else if (availabilityState === "category_deleted") { %>
            <span class="danger-text">Unavailable</span>
          <% } else if (availabilityState === "category_inactive") { %>
            <span class="danger-text">Temporarily unavailable</span>
          <% } else if (availabilityState === "sold_out") { %>
            <span class="danger-text">Sold out</span>
          <% } else if (availabilityState === "variant_unavailable") { %>
            <span class="danger-text">Unavailable options</span>
          <% } else if (availabilityState === "low_stock") { %>
            <span class="low-stock-text">Only <%= product.stock %> left</span>
          <% } else { %>
            <span class="success-text">In stock</span>
          <% } %>
        </div>

        <div class="detail-status-message <%= availabilityState === 'available' ? 'is-ready' : availabilityState === 'low_stock' ? 'is-low-stock' : 'is-warning' %>">
          <p><%= availabilityMessage %></p>
        </div>

        <% if (displaySizes.length || displayColors.length) { %>
          <p class="detail-selected-variant" id="selectedVariantLabel">
            Selected:
            <%= selectedVariantLabelText %>
          </p>
        <% } %>

        <% if (displaySizes.length) { %>
          <div class="variant-box">
            <h3>size</h3>
            <div class="variant-list">
              <% displaySizes.forEach(function(size) { %>
                <button
                  type="button"
                  class="variant-pill <%= defaultVariant && defaultVariant.size === size ? 'active' : '' %>"
                  data-size-option="<%= size %>"
                ><%= size %></button>
              <% }); %>
            </div>
          </div>
        <% } %>

        <% if (displayColors.length) { %>
          <div class="highlight-box detail-color-box">
            <h3>color</h3>
            <div class="color-list">
              <% displayColors.forEach(function(color) { %>
                <button type="button" class="color-pill <%= defaultVariant && defaultVariant.color && defaultVariant.color.toLowerCase() === color.toLowerCase() ? 'active' : '' %>" data-color-option="<%= color %>">
                  <span class="color-dot" style="--detail-color: <%= color.toLowerCase() %>;"></span>
                  <%= color %>
                </button>
              <% }); %>
            </div>
          </div>
        <% } %>

        <div class="detail-action-row">
          <form action="/api/user/cart/add/<%= product._id %>" method="POST">
            <input type="hidden" name="size" id="selectedVariantSize" value="<%= selectedVariantSize %>">
            <input type="hidden" name="color" id="selectedVariantColor" value="<%= selectedVariantColor %>">
            <button class="cart-btn" <%= !canAddToCart ? "disabled" : "" %>>
              <%= addToCartLabel %>
            </button>
          </form>
          <a
            href="<%= canAddToCart ? '/api/user/cart' : '#' %>"
            class="cart-btn detail-cart-link <%= !canAddToCart ? 'cart-btn--disabled-link' : '' %>"
            <%= !canAddToCart ? 'aria-disabled="true"' : '' %>
          >
            Buy now
          </a>
        </div>
      </section>
    </section>

    <% if (relatedProductList.length) { %>
      <section class="detail-related-section">
        <div class="detail-related-head">
          <h2>You may also like</h2>
          <a href="/api/user/products?category=<%= categoryId %>">View more</a>
        </div>

        <div class="detail-related-grid">
          <% relatedProductList.forEach(function(item) { %>
            <a href="/api/user/products/<%= item._id %>" class="detail-related-card">
              <div class="detail-related-card__image">
                <img
                  src="<%= (item.images || [])[item.mainImageIndex || 0] || (item.images || [])[0] || fallbackProductImage %>"
                  alt="<%= item.productName %>"
                />
              </div>
              <h3><%= item.productName %></h3>
              <strong>₹<%= item.displayPrice %></strong>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>
  </main>

  <template id="productDetailData"><%- productDetailJson %></template>
  <script src="/script/product-detail.js"></script>
<%- include("partials/site-footer") %>
</body>
</html>
