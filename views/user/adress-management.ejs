<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Address Management</title>
    <link rel="stylesheet" href="/css/adressmanagement.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <% const redirectValue = redirect || ""; %>
    <main class="neo-scene">
      <section class="neo-card">
        <header class="top-strip">
          <div class="chip-row">
            <a href="/api/auth/home" class="chip">Home</a>
            <a href="/api/user/profile" class="chip">Account</a>
            <a href="#" class="chip">My orders</a>
            <a href="/api/user/adress" class="chip chip-dark">Address</a>
            <a href="/api/user/change-password" class="chip">Password</a>
          </div>

          <form action="/api/user/logout" method="POST">
            <button class="logout-pill" type="submit">Logout</button>
          </form>
        </header>

        <section class="address-main">
          <div class="head-row">
            <div class="head-text">
              <h1>Address Management</h1>
              <p>Add, edit, remove and set your default address</p>
              <% if (redirectValue && redirectValue.startsWith("/api/user/checkout")) { %>
                <p style="margin-top: 12px;">
                  <a href="<%= redirectValue %>" class="chip">Back to Checkout</a>
                </p>
              <% } %>
            </div>

            <div class="mini-avatar">
              <img
                src="<%= user && user.profileImage ? user.profileImage : '/images/avatar.png' %>"
                alt="avatar"
              />
            </div>
          </div>

          <% if (addresses && addresses.length > 0) { %>
            <div class="cards-grid">
              <% addresses.forEach(address => { %>
                <article class="address-card">
                  <div id="view-<%= address._id %>" class="address-content">
                    <div class="address-left">
                      <h3>
                        <%= address.type %>
                        <% if (address.isDefault) { %>
                          <span class="default-badge">Default</span>
                        <% } %>
                      </h3>
                      <p><%= address.street %></p>
                      <p><%= address.city %>, <%= address.state %></p>
                      <p><%= address.pincode %></p>
                    </div>

                    <div class="address-actions">
                      <% if (!address.isDefault) { %>
                        <form action="/api/user/set-default/<%= address._id %>" method="POST">
                          <input type="hidden" name="redirect" value="<%= redirectValue %>" />
                          <button type="submit" class="btn btn-light">Set default</button>
                        </form>
                      <% } %>

                      <button type="button" class="btn btn-light" onclick="enableEdit('<%= address._id %>')">
                        Edit
                      </button>

                      <form
                        action="/api/user/delete-address/<%= address._id %>"
                        method="POST"
                        onsubmit="return confirm('Remove this address?')"
                      >
                        <input type="hidden" name="redirect" value="<%= redirectValue %>" />
                        <button type="submit" class="btn btn-danger">Remove</button>
                      </form>
                    </div>
                  </div>

                  <div id="edit-<%= address._id %>" class="address-edit" style="display:none;">
                    <form action="/api/user/update-address/<%= address._id %>" method="POST" class="edit-form">
                      <input type="hidden" name="redirect" value="<%= redirectValue %>" />
                      <div class="field field-light">
                        <input type="text" name="type" value="<%= address.type %>" required />
                      </div>
                      <div class="field field-light">
                        <input type="text" name="street" value="<%= address.street %>" required />
                      </div>
                      <div class="field field-light">
                        <input type="text" name="city" value="<%= address.city %>" required />
                      </div>
                      <div class="field field-light">
                        <input type="text" name="state" value="<%= address.state %>" required />
                      </div>
                      <div class="field field-light">
                        <input type="text" name="pincode" value="<%= address.pincode %>" required />
                      </div>

                      <div class="edit-buttons">
                        <button type="submit" class="btn btn-dark">Save</button>
                        <button type="button" class="btn btn-light" onclick="cancelEdit('<%= address._id %>')">
                          Cancel
                        </button>
                      </div>
                    </form>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p class="empty-msg">No addresses added yet.</p>
          <% } %>

          <section class="add-new">
            <h3>Add New Address</h3>
            <form action="/api/user/add-address" method="POST" class="add-form">
              <input type="hidden" name="redirect" value="<%= redirectValue %>" />
              <div class="field field-light">
                <input type="text" name="type" placeholder="Home / Office" required />
              </div>
              <div class="field field-light">
                <input type="text" name="street" placeholder="Street" required />
              </div>
              <div class="field field-light">
                <input type="text" name="city" placeholder="City" required />
              </div>
              <div class="field field-light">
                <input type="text" name="state" placeholder="State" required />
              </div>
              <div class="field field-light">
                <input type="text" name="pincode" placeholder="Pincode" required />
              </div>
              <button type="submit" class="btn btn-dark add-btn">Add Address</button>
            </form>
          </section>
        </section>
      </section>
    </main>

    <script>
      function enableEdit(id) {
        document.getElementById("view-" + id).style.display = "none";
        document.getElementById("edit-" + id).style.display = "block";
      }

      function cancelEdit(id) {
        document.getElementById("view-" + id).style.display = "grid";
        document.getElementById("edit-" + id).style.display = "none";
      }
    </script>
    <%- include("partials/site-footer") %>
  </body>
</html>
