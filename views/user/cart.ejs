<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cart</title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="stylesheet" href="/css/cart.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <%- include("partials/storefront-navbar") %>

  <main class="shop-shell">
    <section class="cart-shell">
      <div class="cart-head">
        <h1>Your Cart</h1>
        <p>Review the products you added before checkout.</p>
      </div>

      <% if (cartMessage) { %>
        <p class="cart-page-message" id="cartPageMessage"><%= cartMessage %></p>
      <% } %>

      <% if (!cartItems.length) { %>
        <div class="cart-empty">
          <p>Your cart is empty.</p>
          <a href="/api/user/products" class="cart-link-btn">Continue Shopping</a>
        </div>
      <% } else { %>
        <div class="cart-layout">
          <div class="cart-list">
            <label class="cart-select-all">
              <input type="checkbox" id="selectAllCartItems" checked />
              <span>Select all available items</span>
            </label>

            <% cartItems.forEach((item) => { %>
              <article
                class="cart-item-card"
                data-cart-item
                data-cart-item-id="<%= item.cartItemId %>"
                data-product-id="<%= item.productId %>"
                data-subtotal="<%= item.subtotal %>"
                data-available="<%= item.isAvailable ? '1' : '0' %>"
              >
                <div class="cart-item-check">
                  <input
                    type="checkbox"
                    class="cart-item-checkbox"
                    <%= item.isAvailable ? "checked" : "disabled" %>
                  />
                </div>

                <div class="cart-item-image">
                  <img src="<%= item.productImage %>" alt="<%= item.productName %>" />
                </div>

                <div class="cart-item-copy">
                  <h3><%= item.productName %></h3>
                  <p><%= item.category %></p>
                  <% if (item.size || item.color) { %>
                    <p><%= [item.size ? `Size: ${item.size}` : "", item.color ? `Color: ${item.color}` : ""].filter(Boolean).join(" | ") %></p>
                  <% } %>
                  <span class="cart-item-price">₹<%= item.price %></span>
                  <% if (item.hasDiscount) { %>
                    <span class="cart-item-old-price">₹<%= item.originalPrice %></span>
                  <% } %>

                  <% if (!item.isAvailable) { %>
                    <span class="cart-item-warning"><%= item.availabilityMessage || "Currently unavailable" %></span>
                  <% } else if (item.quantity >= 5) { %>
                    <span class="cart-item-warning">Maximum quantity reached</span>
                  <% } else if (item.quantity >= item.stock) { %>
                    <span class="cart-item-warning">Only <%= item.stock %> in stock</span>
                  <% } %>
                </div>

                <div class="cart-item-actions">
                  <form action="/api/user/cart/update-ajax/<%= item.productId %>" method="POST" class="cart-qty-form" data-cart-qty-form>
                    <input type="hidden" name="action" value="decrement" />
                    <input type="hidden" name="size" value="<%= item.size || '' %>" />
                    <input type="hidden" name="color" value="<%= item.color || '' %>" />
                    <button
                      type="button"
                      class="qty-btn"
                      data-qty-button="decrement"
                      <%= item.disableDecrement ? "disabled" : "" %>
                    >
                      -
                    </button>
                  </form>

                  <span class="cart-qty-value" data-cart-quantity><%= item.quantity %></span>

                  <form action="/api/user/cart/update-ajax/<%= item.productId %>" method="POST" class="cart-qty-form" data-cart-qty-form>
                    <input type="hidden" name="action" value="increment" />
                    <input type="hidden" name="size" value="<%= item.size || '' %>" />
                    <input type="hidden" name="color" value="<%= item.color || '' %>" />
                    <button
                      type="button"
                      class="qty-btn"
                      data-qty-button="increment"
                      <%= item.quantity >= item.stock || item.quantity >= 5 || !item.isAvailable ? "disabled" : "" %>
                    >
                      +
                    </button>
                  </form>
                </div>

                <div class="cart-item-subtotal">
                  <strong data-cart-subtotal>₹<%= item.subtotal %></strong>

                  <form action="/api/user/cart/remove/<%= item.productId %>" method="POST">
                    <input type="hidden" name="size" value="<%= item.size || '' %>" />
                    <input type="hidden" name="color" value="<%= item.color || '' %>" />
                    <button type="submit" class="remove-cart-btn">Remove</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>

          <aside class="cart-summary">
            <h2>Order Summary</h2>

            <div class="cart-summary-row">
              <span>Selected items</span>
              <strong id="selectedItemCount">0</strong>
            </div>

            <div class="cart-summary-row">
              <span>Selected total</span>
              <strong id="selectedGrandTotal">₹0</strong>
            </div>

            <% if (hasUnavailableItems) { %>
              <p class="cart-checkout-warning">
                Some cart items are unavailable or out of stock. Update your cart before checkout.
              </p>
            <% } %>

            <% if (checkoutError) { %>
              <p class="cart-checkout-warning"><%= checkoutError %></p>
            <% } %>

            <p class="cart-checkout-warning cart-selection-warning" id="cartSelectionWarning" hidden>
              Select at least one available item to continue checkout.
            </p>

            <form action="/api/user/cart/checkout" method="POST" id="cartCheckoutForm">
              <div id="selectedProductInputs"></div>
              <button
                type="submit"
                id="cartCheckoutButton"
                class="cart-checkout-btn"
                <%= !canCheckout ? "disabled" : "" %>
              >
                Checkout Selected Items
              </button>
            </form>
          </aside>
        </div>
      <% } %>
    </section>
  </main>

  <script>
    window.addEventListener("pageshow", (event) => {
      if (event.persisted) {
        window.location.reload();
      }
    });

    window.addEventListener("load", () => {
      history.pushState({ cartPage: true }, "", location.href);
    });

    window.addEventListener("popstate", () => {
      window.location.replace("/api/auth/home");
    });

    let cartItemCards = Array.from(document.querySelectorAll("[data-cart-item]"));
    let cartPageMessage = document.getElementById("cartPageMessage");
    let selectAllCartItems = document.getElementById("selectAllCartItems");
    let selectedItemCount = document.getElementById("selectedItemCount");
    let selectedGrandTotal = document.getElementById("selectedGrandTotal");
    let cartCheckoutButton = document.getElementById("cartCheckoutButton");
    let cartSelectionWarning = document.getElementById("cartSelectionWarning");
    let selectedProductInputs = document.getElementById("selectedProductInputs");
    const cartShell = document.querySelector(".cart-shell");
    const cartLayout = document.querySelector(".cart-layout");
    const cartCountBadge = document.querySelector("[data-cart-count-badge]");

    const refreshCartDomReferences = () => {
      cartItemCards = Array.from(document.querySelectorAll("[data-cart-item]"));
      cartPageMessage = document.getElementById("cartPageMessage");
      selectAllCartItems = document.getElementById("selectAllCartItems");
      selectedItemCount = document.getElementById("selectedItemCount");
      selectedGrandTotal = document.getElementById("selectedGrandTotal");
      cartCheckoutButton = document.getElementById("cartCheckoutButton");
      cartSelectionWarning = document.getElementById("cartSelectionWarning");
      selectedProductInputs = document.getElementById("selectedProductInputs");
    };

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");

    const updateCartBadge = (items = []) => {
      if (!cartCountBadge) return;

      const count = Array.isArray(items) ? items.length : 0;

      cartCountBadge.textContent = String(count);
      cartCountBadge.classList.toggle("visible", count > 0);
    };

    const syncCartSelection = () => {
      if (!cartItemCards.length) return;

      const availableCheckboxes = cartItemCards
        .map((card) => card.querySelector(".cart-item-checkbox"))
        .filter((checkbox) => checkbox && !checkbox.disabled);

      const checkedCards = cartItemCards.filter((card) => {
        const checkbox = card.querySelector(".cart-item-checkbox");
        return checkbox && checkbox.checked && !checkbox.disabled;
      });

      if (selectedProductInputs) {
        selectedProductInputs.innerHTML = checkedCards
          .map((card) => {
            const cartItemId = card.dataset.cartItemId;

            if (!cartItemId) return "";

            return `<input type="hidden" name="selectedCartItemIds" value="${cartItemId}">`;
          })
          .join("");
      }

      const total = checkedCards.reduce((sum, card) => {
        return sum + Number(card.dataset.subtotal || 0);
      }, 0);

      if (selectedItemCount) {
        selectedItemCount.textContent = String(checkedCards.length);
      }

      if (selectedGrandTotal) {
        selectedGrandTotal.textContent = `₹${total}`;
      }

      if (cartCheckoutButton) {
        cartCheckoutButton.disabled = checkedCards.length === 0;
      }

      if (cartSelectionWarning) {
        cartSelectionWarning.hidden = checkedCards.length > 0;
      }

      if (selectAllCartItems) {
        const allChecked =
          availableCheckboxes.length > 0 &&
          availableCheckboxes.every((checkbox) => checkbox.checked);
        selectAllCartItems.checked = allChecked;
        selectAllCartItems.disabled = availableCheckboxes.length === 0;
      }
    };

    const getSelectedProductIds = () =>
      cartItemCards
        .filter((card) => {
          const checkbox = card.querySelector(".cart-item-checkbox");
          return checkbox && checkbox.checked && !checkbox.disabled;
        })
        .map((card) => card.dataset.cartItemId);

    const ensureCartMessage = () => {
      let messageNode = document.getElementById("cartPageMessage");

      if (!messageNode) {
        messageNode = document.createElement("p");
        messageNode.className = "cart-page-message";
        messageNode.id = "cartPageMessage";
        document.querySelector(".cart-head")?.insertAdjacentElement("afterend", messageNode);
        cartPageMessage = messageNode;
      }

      return messageNode;
    };

    const showCartMessage = (message) => {
      if (!message) return;
      const messageNode = ensureCartMessage();
      messageNode.textContent = message;

      window.clearTimeout(window.cartMessageTimeout);
      window.cartMessageTimeout = window.setTimeout(() => {
        messageNode.remove();
      }, 3000);
    };

    const getWarningText = (item) => {
      if (!item.isAvailable) {
        return item.availabilityMessage || "Currently unavailable";
      }

      if (item.quantity >= 5) {
        return "Maximum quantity reached";
      }

      if (item.quantity >= item.stock) {
        return `Only ${item.stock} in stock`;
      }

      return "";
    };

    const renderEmptyCart = () => {
      if (!cartShell) return;
      cartShell.innerHTML = `
        <div class="cart-head">
          <h1>Your Cart</h1>
          <p>Review the products you added before checkout.</p>
        </div>
        <div class="cart-empty">
          <p>Your cart is empty.</p>
          <a href="/api/user/products" class="cart-link-btn">Continue Shopping</a>
        </div>
      `;
    };

    const renderCartItem = (item, selectedProductIds) => {
      const warningText = getWarningText(item);
      const isChecked = item.isAvailable && selectedProductIds.has(String(item.cartItemId));

      return `
        <article
          class="cart-item-card"
          data-cart-item
          data-cart-item-id="${escapeHtml(item.cartItemId)}"
          data-product-id="${escapeHtml(item.productId)}"
          data-subtotal="${escapeHtml(item.subtotal)}"
          data-available="${item.isAvailable ? "1" : "0"}"
        >
          <div class="cart-item-check">
            <input
              type="checkbox"
              class="cart-item-checkbox"
              ${isChecked ? "checked" : ""}
              ${item.isAvailable ? "" : "disabled"}
            />
          </div>

          <div class="cart-item-image">
            <img src="${escapeHtml(item.productImage)}" alt="${escapeHtml(item.productName)}" />
          </div>

          <div class="cart-item-copy">
            <h3>${escapeHtml(item.productName)}</h3>
            <p>${escapeHtml(item.category)}</p>
            ${(item.size || item.color) ? `<p>${escapeHtml([item.size ? `Size: ${item.size}` : "", item.color ? `Color: ${item.color}` : ""].filter(Boolean).join(" | "))}</p>` : ""}
            <span class="cart-item-price">₹${escapeHtml(item.price)}</span>
            ${item.hasDiscount ? `<span class="cart-item-old-price">₹${escapeHtml(item.originalPrice)}</span>` : ""}
            ${warningText ? `<span class="cart-item-warning">${escapeHtml(warningText)}</span>` : ""}
          </div>

          <div class="cart-item-actions">
            <form action="/api/user/cart/update-ajax/${escapeHtml(item.productId)}" method="POST" class="cart-qty-form" data-cart-qty-form>
              <input type="hidden" name="action" value="decrement" />
              <input type="hidden" name="size" value="${escapeHtml(item.size || "")}" />
              <input type="hidden" name="color" value="${escapeHtml(item.color || "")}" />
              <button
                type="button"
                class="qty-btn"
                data-qty-button="decrement"
                ${item.disableDecrement ? "disabled" : ""}
              >
                -
              </button>
            </form>

            <span class="cart-qty-value" data-cart-quantity>${escapeHtml(item.quantity)}</span>

            <form action="/api/user/cart/update-ajax/${escapeHtml(item.productId)}" method="POST" class="cart-qty-form" data-cart-qty-form>
              <input type="hidden" name="action" value="increment" />
              <input type="hidden" name="size" value="${escapeHtml(item.size || "")}" />
              <input type="hidden" name="color" value="${escapeHtml(item.color || "")}" />
              <button
                type="button"
                class="qty-btn"
                data-qty-button="increment"
                ${item.quantity >= item.stock || item.quantity >= 5 || !item.isAvailable ? "disabled" : ""}
              >
                +
              </button>
            </form>
          </div>

          <div class="cart-item-subtotal">
            <strong data-cart-subtotal>₹${escapeHtml(item.subtotal)}</strong>

            <form action="/api/user/cart/remove/${escapeHtml(item.productId)}" method="POST">
              <input type="hidden" name="size" value="${escapeHtml(item.size || "")}" />
              <input type="hidden" name="color" value="${escapeHtml(item.color || "")}" />
              <button type="submit" class="remove-cart-btn">Remove</button>
            </form>
          </div>
        </article>
      `;
    };

    const renderCartLayout = (payload, selectedIds = new Set()) => {
      if (!cartLayout) return;

      const items = Array.isArray(payload.cartItems) ? payload.cartItems : [];

      if (!items.length) {
        updateCartBadge([]);
        renderEmptyCart();
        refreshCartDomReferences();
        return;
      }

      cartLayout.innerHTML = `
        <div class="cart-list">
          <label class="cart-select-all">
            <input type="checkbox" id="selectAllCartItems" />
            <span>Select all available items</span>
          </label>
          ${items.map((item) => renderCartItem(item, selectedIds)).join("")}
        </div>

        <aside class="cart-summary">
          <h2>Order Summary</h2>

          <div class="cart-summary-row">
            <span>Selected items</span>
            <strong id="selectedItemCount">0</strong>
          </div>

          <div class="cart-summary-row">
            <span>Selected total</span>
            <strong id="selectedGrandTotal">₹0</strong>
          </div>

          ${payload.hasUnavailableItems ? `
            <p class="cart-checkout-warning">
              Some cart items are unavailable or out of stock. Update your cart before checkout.
            </p>
          ` : ""}

          <p class="cart-checkout-warning cart-selection-warning" id="cartSelectionWarning" hidden>
            Select at least one available item to continue checkout.
          </p>

          <form action="/api/user/cart/checkout" method="POST" id="cartCheckoutForm">
            <div id="selectedProductInputs"></div>
            <button
              type="submit"
              id="cartCheckoutButton"
              class="cart-checkout-btn"
              ${payload.canCheckout ? "" : "disabled"}
            >
              Checkout Selected Items
            </button>
          </form>
        </aside>
      `;

      refreshCartDomReferences();
      updateCartBadge(items);
      syncCartSelection();
    };

    const applyCartState = (payload) => {
      const previouslySelected = new Set(getSelectedProductIds());
      renderCartLayout(payload, previouslySelected);
    };

    const requestCartQuantityUpdate = async (form) => {
      const buttons = Array.from(form.closest("[data-cart-item]")?.querySelectorAll(".qty-btn") || []);
      let restoreButtons = true;

      buttons.forEach((button) => {
        button.disabled = true;
      });

      try {
        const response = await fetch(form.getAttribute("action"), {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
            "X-Requested-With": "XMLHttpRequest",
            "Accept": "application/json"
          },
          body: (() => {
            const params = new URLSearchParams(new FormData(form));
            params.set("ajax", "1");
            return params.toString();
          })()
        });

        const contentType = response.headers.get("content-type") || "";
        if (!contentType.includes("application/json")) {
          const responseText = await response.text();
          throw new Error(responseText || "Invalid cart response");
        }

        const payload = await response.json();

        if (!response.ok || !payload.success) {
          showCartMessage(payload.message || "Unable to update cart quantity right now.");
          return;
        }

        if (!Array.isArray(payload.cartItems)) {
          throw new Error(payload.message || "Invalid cart items payload");
        }

        applyCartState(payload);
        restoreButtons = false;
      } catch (error) {
        showCartMessage(error?.message || "Unable to update cart quantity right now.");
      } finally {
        if (restoreButtons) {
          buttons.forEach((button) => {
            button.disabled = false;
          });
        }
      }
    };

    cartShell?.addEventListener("click", (event) => {
      const button = event.target.closest("[data-qty-button]");
      if (!button) return;

      const form = button.closest("[data-cart-qty-form]");
      if (!form) return;

      event.preventDefault();
      requestCartQuantityUpdate(form);
    });

    cartShell?.addEventListener("change", (event) => {
      if (event.target?.id === "selectAllCartItems") {
        cartItemCards.forEach((card) => {
          const checkbox = card.querySelector(".cart-item-checkbox");
          if (checkbox && !checkbox.disabled) {
            checkbox.checked = event.target.checked;
          }
        });

        syncCartSelection();
        return;
      }

      if (event.target?.classList?.contains("cart-item-checkbox")) {
        syncCartSelection();
      }
    });

    refreshCartDomReferences();
    syncCartSelection();

    if (cartPageMessage) {
      window.setTimeout(() => {
        cartPageMessage.remove();

        const url = new URL(window.location.href);
        url.searchParams.delete("message");
        window.history.replaceState({}, "", url.pathname + url.search);
      }, 3000);
    }
  </script>
</body>
</html>
