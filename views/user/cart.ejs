<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cart</title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="stylesheet" href="/css/cart.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <%- include("partials/storefront-navbar") %>

  <main class="shop-shell">
    <section class="cart-shell">
      <div class="cart-head">
        <h1>Your Cart</h1>
        <p>Review the products you added before checkout.</p>
      </div>

      <% if (!cartItems.length) { %>
        <div class="cart-empty">
          <p>Your cart is empty.</p>
          <a href="/api/user/products" class="cart-link-btn">Continue Shopping</a>
        </div>
      <% } else { %>
        <div class="cart-layout">
          <div class="cart-list">
            <label class="cart-select-all">
              <input type="checkbox" id="selectAllCartItems" checked />
              <span>Select all available items</span>
            </label>

            <% cartItems.forEach((item) => { %>
              <article
                class="cart-item-card"
                data-cart-item
                data-subtotal="<%= item.subtotal %>"
                data-available="<%= item.isAvailable ? '1' : '0' %>"
              >
                <div class="cart-item-check">
                  <input
                    type="checkbox"
                    class="cart-item-checkbox"
                    <%= item.isAvailable ? "checked" : "disabled" %>
                  />
                </div>

                <div class="cart-item-image">
                  <img src="<%= item.productImage %>" alt="<%= item.productName %>" />
                </div>

                <div class="cart-item-copy">
                  <h3><%= item.productName %></h3>
                  <p><%= item.category %></p>
                  <span class="cart-item-price">₹<%= item.price %></span>

                  <% if (!item.isAvailable) { %>
                    <span class="cart-item-warning">Currently unavailable</span>
                  <% } %>
                </div>

                <div class="cart-item-actions">
                  <form action="/api/user/cart/update/<%= item.productId %>" method="POST" class="cart-qty-form">
                    <input type="hidden" name="action" value="decrement" />
                    <button
                      type="submit"
                      class="qty-btn"
                    >
                      -
                    </button>
                  </form>

                  <span class="cart-qty-value"><%= item.quantity %></span>

                  <form action="/api/user/cart/update/<%= item.productId %>" method="POST" class="cart-qty-form">
                    <input type="hidden" name="action" value="increment" />
                    <button
                      type="submit"
                      class="qty-btn"
                      <%= item.quantity >= item.stock || !item.isAvailable ? "disabled" : "" %>
                    >
                      +
                    </button>
                  </form>
                </div>

                <div class="cart-item-subtotal">
                  <strong>₹<%= item.subtotal %></strong>

                  <form action="/api/user/cart/remove/<%= item.productId %>" method="POST">
                    <button type="submit" class="remove-cart-btn">Remove</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>

          <aside class="cart-summary">
            <h2>Order Summary</h2>

            <div class="cart-summary-row">
              <span>Selected items</span>
              <strong id="selectedItemCount">0</strong>
            </div>

            <div class="cart-summary-row">
              <span>Selected total</span>
              <strong id="selectedGrandTotal">₹0</strong>
            </div>

            <% if (hasUnavailableItems) { %>
              <p class="cart-checkout-warning">
                Some cart items are unavailable or out of stock. Update your cart before checkout.
              </p>
            <% } %>

            <p class="cart-checkout-warning cart-selection-warning" id="cartSelectionWarning" hidden>
              Select at least one available item to continue checkout.
            </p>

            <button
              type="button"
              id="cartCheckoutButton"
              class="cart-checkout-btn"
              <%= !canCheckout ? "disabled" : "" %>
            >
              Checkout Selected Items
            </button>
          </aside>
        </div>
      <% } %>
    </section>
  </main>

  <script>
    const cartItemCards = Array.from(document.querySelectorAll("[data-cart-item]"));
    const selectAllCartItems = document.getElementById("selectAllCartItems");
    const selectedItemCount = document.getElementById("selectedItemCount");
    const selectedGrandTotal = document.getElementById("selectedGrandTotal");
    const cartCheckoutButton = document.getElementById("cartCheckoutButton");
    const cartSelectionWarning = document.getElementById("cartSelectionWarning");

    const syncCartSelection = () => {
      if (!cartItemCards.length) return;

      const availableCheckboxes = cartItemCards
        .map((card) => card.querySelector(".cart-item-checkbox"))
        .filter((checkbox) => checkbox && !checkbox.disabled);

      const checkedCards = cartItemCards.filter((card) => {
        const checkbox = card.querySelector(".cart-item-checkbox");
        return checkbox && checkbox.checked && !checkbox.disabled;
      });

      const total = checkedCards.reduce((sum, card) => {
        return sum + Number(card.dataset.subtotal || 0);
      }, 0);

      if (selectedItemCount) {
        selectedItemCount.textContent = String(checkedCards.length);
      }

      if (selectedGrandTotal) {
        selectedGrandTotal.textContent = `₹${total}`;
      }

      if (cartCheckoutButton) {
        cartCheckoutButton.disabled = checkedCards.length === 0;
      }

      if (cartSelectionWarning) {
        cartSelectionWarning.hidden = checkedCards.length > 0;
      }

      if (selectAllCartItems) {
        const allChecked =
          availableCheckboxes.length > 0 &&
          availableCheckboxes.every((checkbox) => checkbox.checked);
        selectAllCartItems.checked = allChecked;
        selectAllCartItems.disabled = availableCheckboxes.length === 0;
      }
    };

    cartItemCards.forEach((card) => {
      const checkbox = card.querySelector(".cart-item-checkbox");
      if (checkbox) {
        checkbox.addEventListener("change", syncCartSelection);
      }
    });

    selectAllCartItems?.addEventListener("change", () => {
      cartItemCards.forEach((card) => {
        const checkbox = card.querySelector(".cart-item-checkbox");
        if (checkbox && !checkbox.disabled) {
          checkbox.checked = selectAllCartItems.checked;
        }
      });

      syncCartSelection();
    });

    syncCartSelection();
  </script>
</body>
</html>
