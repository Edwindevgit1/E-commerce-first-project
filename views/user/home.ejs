<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
    <link rel="stylesheet" href="/css/home.css" />
    <link rel="stylesheet" href="/css/storefront-navbar.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-orb orb-3"></div>

    <%- include("partials/storefront-navbar") %>

    <main class="page-wrap">
      <section class="hero glass">
        <img src="/images/bannerimg.jpg.png" alt="Hero" />
        <div class="hero-text glass-inner">
          <h1>SUMMER IS HERE, AND IT'S TIME TO GET OUT AND ENJOY THE SUN!</h1>
          <p>The best way to beat the heat is to buy new clothes.</p>
          <button>Hot Deals</button>
        </div>
      </section>

      <section class="summer-banner glass">
        <img src="/images/secondbanner.png" alt="Summer banner" />
        <div class="banner-text glass-inner">
          <h1>SUMMER POSSIBILITIES</h1>
          <button>Hot Deals</button>
        </div>
      </section>
    </main>

    <%- include("partials/site-footer") %>
    <script>
      window.addEventListener("pageshow", function (event) {
      if (event.persisted) {
      window.location.reload();
      }
      });
    </script>
  </body>
</html>
