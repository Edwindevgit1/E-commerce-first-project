<!DOCTYPE html>
<html>
<head>
  <title>Change Password</title>
  <link rel="stylesheet" href="/css/changepassword.css">
</head>
<body>

<header class="navbar">
  <div class="logo">NIKE</div>
  <nav>
    <a href="#">Men</a>
    <a href="#">Women</a>
    <a href="#">Shoe</a>
    <a href="#">Hot deals</a>
  </nav>
</header>

<div class="profile-container">


  <div class="sidebar">

    <div class="sidebar-avatar">
      <img 
        src="<%= user.profileImage ? user.profileImage : '/images/avatar.png' %>" 
        alt="avatar"
      >
    </div>

    <ul>
      <li>
        <a href="/api/user/profile">Account information</a>
      </li>

      <li>
        <a href="#">My orders</a>
      </li>

      <li>
        <a href="/api/user/adress">Address management</a>
      </li>

      <li class="active">
        <a href="/api/user/change-password">Change password</a>
      </li>
    </ul>

    <form action="/api/auth/logout" method="POST">
      <button class="logout-btn">Logout</button>
    </form>

  </div>


  <div class="password-main">

    <h1>Change Password</h1>

    <% if (typeof error !== "undefined") { %>
      <p class="error"><%= error %></p>
    <% } %>

    <% if (typeof success !== "undefined") { %>
      <p class="success"><%= success %></p>
    <% } %>
    <form action="/api/user/change-password" method="POST" class="password-form">

      <div class="form-group">
        <label>Current Password</label>
        <input type="password" name="currentPassword" required>
      </div>
    
      <div class="form-group">
        <label>New Password</label>
        <input type="password" name="newPassword" required>
      </div>
    
      <div class="form-group">
        <label>Confirm Password</label>
        <input type="password" name="confirmPassword" required>
      </div>
    
      <button type="submit" class="update-btn">
        Update Password
      </button>
    
    </form>

  </div>

</div>

</body>
</html>