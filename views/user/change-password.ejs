<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password</title>
    <link rel="stylesheet" href="/css/changepassword.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <main class="neo-scene">
      <section class="neo-card">

        <header class="top-strip">
          <div class="chip-row">
            <a href="/api/auth/home" class="chip">Home</a>
            <a href="/api/user/profile" class="chip">Account information</a>
            <a href="/api/user/orders" class="chip">My orders</a>
            <a href="/api/user/adress" class="chip">Address management</a>
            <a href="/api/user/change-password" class="chip chip-dark">Change password</a>
          </div>

          <form action="/api/user/logout" method="POST">
            <button class="logout-pill" type="submit">Logout</button>
          </form>
        </header>

        <section class="password-main">

          <div class="head-row">
            <div class="head-text">
              <h1><%= user.password ? "Change Password" : "Set Password" %></h1>
              <p>Use a strong password to secure your account</p>
            </div>

            <div class="mini-avatar">
              <img
                src="<%= user.profileImage ? user.profileImage : '/images/avatar.png' %>"
                alt="avatar"
              />
            </div>
          </div>

          <div class="message-slot">
            <% if (typeof error !== "undefined" && error) { %>
              <p id="errorBox" class="error"><%= error %></p>
            <% } else if (typeof success !== "undefined" && success) { %>
              <p id="successBox" class="success"><%= success %></p>
            <% } else { %>
              <div class="message-placeholder"></div>
            <% } %>
          </div>

          <form action="/api/user/change-password" method="POST" class="password-form">

            <% if (user.password) { %>
            <!-- Current password (only for users who already have password) -->
            <div class="field-wrap">
              <label>Current Password</label>
              <div class="field field-dark password-field">
                <input
                  type="password"
                  name="currentPassword"
                  id="currentPassword"
                  placeholder="Current password"
                  required
                />
                <button type="button" class="toggle-password" data-target="currentPassword" aria-label="Show password"></button>
              </div>
            </div>
            <% } %>

            <!-- New password -->
            <div class="field-wrap">
              <label>New Password</label>
              <div class="field field-dark password-field">
                <input
                  type="password"
                  name="newPassword"
                  id="newPassword"
                  placeholder="New password"
                  required
                />
                <button type="button" class="toggle-password" data-target="newPassword" aria-label="Show password"></button>
              </div>
            </div>

            <!-- Confirm password -->
            <div class="field-wrap">
              <label>Confirm Password</label>
              <div class="field field-dark password-field">
                <input
                  type="password"
                  name="confirmPassword"
                  id="confirmPassword"
                  placeholder="Confirm password"
                  required
                />
                <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Show password"></button>
              </div>
            </div>

            <button type="submit" class="btn btn-dark update-btn">
              <%= user.password ? "Update Password" : "Set Password" %>
            </button>

          </form>

        </section>
      </section>
    </main>

    <script>
      window.addEventListener("pageshow", function (event) {
      if (event.persisted) {
      window.location.reload();
      }
      });
      const eyeIcon = `
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 5c5.23 0 9.27 4.11 10.75 6.04a1.5 1.5 0 0 1 0 1.92C21.27 14.89 17.23 19 12 19S2.73 14.89 1.25 12.96a1.5 1.5 0 0 1 0-1.92C2.73 9.11 6.77 5 12 5Zm0 2c-3.98 0-7.22 3.01-8.66 5 1.44 1.99 4.68 5 8.66 5s7.22-3.01 8.66-5C19.22 10.01 15.98 7 12 7Zm0 1.75A3.25 3.25 0 1 1 8.75 12 3.25 3.25 0 0 1 12 8.75Zm0 2A1.25 1.25 0 1 0 13.25 12 1.25 1.25 0 0 0 12 10.75Z"
          />
        </svg>
      `;

      const eyeOffIcon = `
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M3.53 2.47a.75.75 0 1 0-1.06 1.06l2.1 2.1A15.6 15.6 0 0 0 1.25 9.04a1.5 1.5 0 0 0 0 1.92C2.73 12.89 6.77 17 12 17c1.73 0 3.31-.45 4.71-1.14l3.76 3.76a.75.75 0 1 0 1.06-1.06Zm7.54 6.48 3.48 3.48c.12-.3.18-.62.18-.93A2.75 2.75 0 0 0 11.98 8.75c-.31 0-.61.07-.91.2ZM9.9 11.9l2.2 2.2a1.25 1.25 0 0 1-2.2-2.2Zm9.53.1c-1.44 1.99-4.68 5-8.66 5-3.98 0-7.22-3.01-8.66-5 .88-1.22 2.38-2.78 4.3-3.87l1.13 1.13A4.25 4.25 0 0 0 13.74 15l1.37 1.37c3.17-1.13 5.62-3.64 6.64-5a13.95 13.95 0 0 0-4.3-3.87l1.07 1.07c.35.24.65.49.91.74Z"
          />
        </svg>
      `;

      function syncPasswordToggle(btn, isPassword) {
        btn.innerHTML = isPassword ? eyeIcon : eyeOffIcon;
        btn.setAttribute("aria-label", isPassword ? "Show password" : "Hide password");
      }

      document.querySelectorAll(".toggle-password").forEach((btn) => {
        const input = document.getElementById(btn.dataset.target);
        if (!input) return;

        syncPasswordToggle(btn, input.type === "password");

        btn.addEventListener("click", () => {
          const isPassword = input.type === "password";
          input.type = isPassword ? "text" : "password";
          syncPasswordToggle(btn, input.type === "password");
        });
      });

      setTimeout(() => {
        const errorBox = document.getElementById("errorBox");
        const successBox = document.getElementById("successBox");
        if (errorBox) errorBox.style.display = "none";
        if (successBox) successBox.style.display = "none";
      }, 3000);
    </script>

    <%- include("partials/site-footer") %>
  </body>
</html>
