<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Detail</title>
    <link rel="stylesheet" href="/css/user-orders.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <main class="neo-scene">
    <section class="neo-card">
      <header class="top-strip">
        <div class="chip-row">
          <a href="/api/auth/home" class="chip">Home</a>
          <a href="/api/user/profile" class="chip">Account</a>
          <a href="/api/user/orders" class="chip chip-dark">My orders</a>
          <a href="/api/user/adress" class="chip">Address management</a>
          <a href="/api/user/change-password" class="chip">Change password</a>
        </div>

        <form action="/api/user/logout" method="POST">
          <button class="logout-pill" type="submit">Logout</button>
        </form>
      </header>

      <section class="orders-main">
        <div class="head-row">
          <div class="head-text">
            <h1>Order Detail</h1>
            <p>Review items, status, payment, and available actions for this order.</p>
          </div>

          <div class="mini-avatar">
            <img
              src="<%= user && user.profileImage ? user.profileImage : '/images/avatar.png' %>"
              alt="avatar"
            />
          </div>
        </div>

        <div class="message-slot">
          <% if (message) { %>
            <p class="orders-message orders-message--success"><%= message %></p>
          <% } else if (error) { %>
            <p class="orders-message orders-message--error"><%= error %></p>
          <% } else { %>
            <div class="message-placeholder"></div>
          <% } %>
        </div>

        <div class="orders-inline-links">
          <a href="/api/user/orders" class="orders-link">Back to Orders</a>
          <a href="/api/user/orders/<%= order._id %>/invoice" class="orders-link orders-link--primary">Download Invoice</a>
        </div>

        <section class="order-detail-grid">
          <div class="order-items-panel">
            <h2>Items</h2>
            <% order.items.forEach((item, index) => { %>
              <article class="order-item-card">
                <img src="<%= item.productImage || 'https://placehold.co/160x160?text=Item' %>" alt="<%= item.productName %>" />
                <div>
                  <strong><%= item.productName %></strong>
                  <p>Qty: <%= item.quantity %></p>
                  <p>Price: ₹<%= item.price %></p>
                  <p>Subtotal: ₹<%= item.subtotal %></p>
                  <p>
                    Status:
                    <span class="status-pill status-pill--<%= item.status %>"><%= item.status.replaceAll("_", " ") %></span>
                  </p>

                  <% if (["pending", "shipped"].includes(item.status) && !item.cancellationRejected) { %>
                    <form method="POST" action="/api/user/orders/<%= order._id %>/items/<%= index %>/cancel" class="orders-action-group">
                      <input type="text" name="reason" placeholder="Cancellation reason (optional)" />
                      <button type="submit" class="orders-btn">Cancel This Item</button>
                    </form>
                  <% } %>

                  <% if (item.status === "delivered") { %>
                    <form method="POST" action="/api/user/orders/<%= order._id %>/items/<%= index %>/return" class="orders-action-group">
                      <input type="text" name="reason" placeholder="Return reason" />
                      <button type="submit" class="orders-btn">Return This Item</button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>

          <aside class="order-detail-summary">
            <h2>Summary</h2>
            <div class="order-detail-row"><strong>Order ID:</strong> <%= order.orderId %></div>
            <div class="order-detail-row"><strong>Status:</strong> <%= order.status.replaceAll("_", " ") %></div>
            <div class="order-detail-row"><strong>Order Date:</strong> <%= new Date(order.createdAt).toLocaleDateString("en-IN") %></div>
            <div class="order-detail-row"><strong>Payment:</strong> <%= order.paymentMethod %></div>
            <div class="order-detail-row"><strong>Total:</strong> ₹<%= order.grandTotal %></div>

            <%
              const canCancelFullOrder = ["pending", "shipped"].includes(order.status) &&
                order.items.some(function(item) {
                  return ["pending", "shipped"].includes(item.status) && !item.cancellationRejected;
                });
            %>
            <% if (canCancelFullOrder) { %>
              <form method="POST" action="/api/user/orders/<%= order._id %>/cancel" class="orders-action-group">
                <input type="text" name="reason" placeholder="Cancellation reason (optional)" />
                <button type="submit" class="orders-btn">Cancel Full Order</button>
              </form>
            <% } %>

            <% if (order.status === "delivered") { %>
              <form method="POST" action="/api/user/orders/<%= order._id %>/return" class="orders-action-group">
                <input type="text" name="reason" placeholder="Return reason" />
                <button type="submit" class="orders-btn">Return Full Order</button>
              </form>
            <% } %>
          </aside>
        </section>
      </section>
    </section>
  </main>

  <%- include("partials/site-footer") %>
<script>
  setTimeout(() => {
    document.querySelectorAll(".orders-message").forEach((msg) => msg.remove());
  }, 3000);
</script>
</body>
</html>
