<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Successful</title>
  <link rel="stylesheet" href="/css/storefront-navbar.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <style>
    :root {
      --page-bg: #eef5ff;
      --panel-bg: rgba(255, 255, 255, 0.88);
      --panel-border: #c8d8fb;
      --text-main: #183b7a;
      --text-soft: #5f7fb8;
      --accent: #244b93;
      --accent-soft: #dce9ff;
      --success: #3ba76d;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Sora", sans-serif;
      background:
        radial-gradient(circle at top right, rgba(138, 180, 255, 0.22), transparent 25%),
        linear-gradient(180deg, #f7fbff 0%, var(--page-bg) 100%);
      color: var(--text-main);
    }
    .success-shell {
      width: min(100%, 760px);
      margin: 18px auto 40px;
      padding: 0 14px;
    }
    .success-card {
      background: var(--panel-bg);
      border: 1px solid var(--panel-border);
      border-radius: 24px;
      box-shadow: 0 16px 34px rgba(36, 75, 147, 0.1);
      padding: 16px;
    }
    .success-panel {
      border: 1px solid var(--panel-border);
      border-radius: 20px;
      padding: 28px 18px 22px;
      text-align: center;
      background: linear-gradient(180deg, rgba(255,255,255,0.75), rgba(237,244,255,0.9));
    }
    .checkmark {
      width: clamp(74px, 12vw, 96px);
      height: clamp(74px, 12vw, 96px);
      border-radius: 50%;
      background: var(--accent-soft);
      color: #2d62bb;
      display: grid;
      place-items: center;
      font-size: clamp(34px, 5vw, 48px);
      font-weight: 800;
      margin: 0 auto 14px;
    }
    .statement-box {
      margin: 0 auto 20px;
      max-width: 560px;
      padding: 16px;
      border-radius: 18px;
      border: 1px solid var(--panel-border);
      background: rgba(255,255,255,0.95);
      text-align: left;
    }
    .statement-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-top: 10px;
      color: var(--text-soft);
      font-size: 13px;
    }
    .statement-row strong {
      color: var(--accent);
    }
    h1 {
      margin: 0 0 10px;
      font-size: clamp(26px, 4vw, 34px);
      line-height: 1.1;
      color: var(--accent);
    }
    .subtitle {
      max-width: 520px;
      margin: 0 auto 20px;
      font-size: clamp(14px, 1.8vw, 15px);
      line-height: 1.5;
      color: var(--text-soft);
    }
    .meta-row {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }
    .meta-pill {
      min-width: 140px;
      padding: 10px 14px;
      border-radius: 16px;
      border: 1px solid var(--panel-border);
      background: #fff;
    }
    .meta-pill--accent {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }
    .meta-label {
      display: block;
      font-size: 11px;
      margin-bottom: 3px;
      opacity: 0.8;
    }
    .meta-value {
      display: block;
      font-weight: 700;
      font-size: 14px;
    }
    .meta-value--success {
      color: var(--success);
    }
    .action-row {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .success-btn {
      min-width: 170px;
      padding: 12px 16px;
      border-radius: 14px;
      border: 1px solid var(--panel-border);
      background: #fff;
      color: var(--accent);
      font-weight: 700;
      text-decoration: none;
      font-size: 13px;
    }
    .success-btn--primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    @media (max-width: 768px) {
      .success-shell {
        margin: 14px auto 28px;
        padding: 0 10px;
      }
      .success-card {
        padding: 12px;
        border-radius: 18px;
      }
      .success-panel {
        padding: 22px 14px 18px;
        border-radius: 16px;
      }
      .meta-pill, .success-btn { width: 100%; min-width: 0; }
    }
  </style>
</head>
<body>
  <%- include("partials/storefront-navbar") %>
  <%
    const isOnlinePaid = order.paymentMethod === "RAZORPAY" || order.paymentMethod === "WALLET";
    const pageTitle = isOnlinePaid ? "Payment successful" : "Order placed successfully";
    const pageSubtitle = isOnlinePaid
      ? "Thank you! Your payment is confirmed and your order is now being prepared for shipment."
      : "Thank you! Your order is confirmed and will be collected as cash on delivery.";
  %>

  <main class="success-shell">
    <section class="success-card">
      <div class="success-panel">
        <div class="checkmark">✓</div>
        <h1><%= pageTitle %></h1>
        <p class="subtitle">
          <%= pageSubtitle %>
        </p>

        <div class="statement-box">
          <div class="statement-row"><span>Order Total</span><strong>₹<%= Number(order.grandTotal || 0).toLocaleString("en-IN") %></strong></div>
          <div class="statement-row"><span>Payment Method</span><strong><%= order.paymentMethod %></strong></div>
          <div class="statement-row"><span>Payment Status</span><strong><%= order.paymentStatus %></strong></div>
          <div class="statement-row"><span>Order Status</span><strong><%= order.status %></strong></div>
        </div>

        <div class="meta-row">
          <div class="meta-pill">
            <span class="meta-label">Order ID</span>
            <span class="meta-value"><%= order.orderId %></span>
          </div>
          <div class="meta-pill">
            <span class="meta-label">Payment</span>
            <span class="meta-value <%= order.paymentMethod === 'COD' ? '' : 'meta-value--success' %>">
              <%= order.paymentMethod === "COD" ? "Cash on Delivery" : order.paymentStatus %>
            </span>
          </div>
          <div class="meta-pill meta-pill--accent">
            <span class="meta-label">Status</span>
            <span class="meta-value"><%= order.status %></span>
          </div>
        </div>

        <div class="action-row">
          <a href="/api/user/orders/<%= order._id %>" class="success-btn">Order Details</a>
          <a href="/api/user/products" class="success-btn success-btn--primary">Continue Shopping</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
